{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_015HAbxyZ8Ut31ntQLFGo1HF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012Ed5HyKPKjSnR2fYJHH8zC","name":"Write","input":{"file_path":"/tmp/agent-factoring-3/library/snfs_lite.c","content":"/*\n * snfs_lite.c — Simplified Number Field Sieve for medium-sized numbers\n *\n * Novel approach: apply NFS-style algebraic norm reduction to numbers\n * in the 40-80 digit range, where standard NFS is normally considered\n * too heavyweight. Uses:\n * 1. Base-m polynomial construction (no special form needed)\n * 2. Brute-force (a,b) evaluation (no lattice sieving)\n * 3. Trial division for smoothness on both sides\n * 4. Standard GF(2) linear algebra\n *\n * The key hypothesis: even with brute-force evaluation (no lattice sieve),\n * the smaller algebraic norm values (~N^{1/3} vs ~N^{1/2} for QS) might\n * compensate for the double-smoothness requirement, giving better scaling\n * for medium-sized numbers.\n *\n * Usage: ./snfs_lite <N>\n * Output: FACTOR: <p>\n */\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <math.h>\n#include <time.h>\n#include <gmp.h>\n#include <ecm.h>\n\n#define MAX_FB 8192\n#define MAX_RELS (MAX_FB + 512)\n\ntypedef struct {\n    int a;           /* rational coefficient */\n    int b;           /* algebraic coefficient */\n    /* Relation: (a - b*m)^2 or more precisely:\n     * rat_val = a - b*m\n     * alg_val = b^d * f(a/b) = resultant_like algebraic norm\n     * We need both to be smooth. */\n} candidate_t;\n\ntypedef struct {\n    int a, b;\n    unsigned char *exp;       /* GF(2) exponent vector for both sides */\n    unsigned long *full_exp;  /* full exponents for square root */\n    mpz_t x_rat;              /* x value for rational side */\n} rel_t;\n\n/* Polynomial f(x) = c_d * x^d + ... + c_0 with f(m) ≡ 0 (mod N) */\nstatic int poly_deg;\nstatic mpz_t poly_coeff[8]; /* up to degree 7 */\nstatic mpz_t poly_m;        /* m such that f(m) ≡ 0 (mod N) */\nstatic mpz_t gN;\n\n/* Factor bases */\nstatic unsigned long rat_fb[MAX_FB]; /* rational factor base primes */\nstatic int rat_fb_size = 0;\nstatic unsigned long alg_fb[MAX_FB]; /* algebraic factor base (prime, root) pairs */\nstatic int alg_fb_roots[MAX_FB];     /* root of f mod p */\nstatic int alg_fb_size = 0;\n\nstatic rel_t rels[MAX_RELS];\nstatic int nrels = 0;\nstatic int target_rels = 0;\nstatic double gStart;\n\nstatic double walltime(void) {\n    struct timespec ts;\n    clock_gettime(CLOCK_MONOTONIC, &ts);\n    return ts.tv_sec + ts.tv_nsec * 1e-9;\n}\n\nstatic int is_prime(unsigned long n) {\n    if (n < 2) return 0;\n    if (n < 4) return 1;\n    if (n % 2 == 0 || n % 3 == 0) return 0;\n    for (unsigned long d = 5; d * d <= n; d += 6)\n        if (n % d == 0 || n % (d+2) == 0) return 0;\n    return 1;\n}\n\n/* Polynomial selection: base-m method\n * Write N in base m: N = c_d * m^d + c_{d-1} * m^{d-1} + ... + c_0\n * Then f(x) = c_d * x^d + ... + c_0 and f(m) = N. */\nstatic void select_polynomial(int degree) {\n    poly_deg = degree;\n    for (int i = 0; i <= degree; i++)\n        mpz_init(poly_coeff[i]);\n    mpz_init(poly_m);\n\n    /* m = floor(N^{1/(d+1)}) approximately */\n    /* For degree d, optimal m ≈ N^{1/(d+1)} */\n    mpz_t rem, base;\n    mpz_init(rem);\n    mpz_init(base);\n\n    /* Compute m = floor(N^(1/(d+1))) */\n    mpz_root(poly_m, gN, degree + 1);\n    /* Adjust slightly for better coefficients */\n    /* Try m, m+1, m-1 and pick the one with smallest max coefficient */\n\n    mpz_set(rem, gN);\n    /* Extract digits in base m */\n    for (int i = 0; i <= degree; i++) {\n        mpz_tdiv_qr(rem, poly_coeff[i], rem, poly_m);\n    }\n    /* rem should be 0 if m is chosen perfectly, or small otherwise */\n    /* For the leading coefficient, it's whatever's left in rem */\n    if (mpz_sgn(rem) != 0) {\n        /* Not perfectly base-m representable — use the last coeff + rem */\n        mpz_addmul(poly_coeff[degree], rem, poly_m);\n        /* Actually, let's redo: just divide N by m repeatedly */\n    }\n\n    /* Redo: proper base-m decomposition */\n    mpz_set(rem, gN);\n    for (int i = 0; i <= degree; i++) {\n        mpz_fdiv_qr(rem, poly_coeff[i], rem, poly_m);\n    }\n    /* The remaining 'rem' should be 0 or we add it to the top coefficient */\n    if (mpz_sgn(rem) != 0) {\n        /* Leading coefficient absorbs remainder */\n        mpz_add(poly_coeff[degree], poly_coeff[degree], rem);\n        /* But this might make the leading coeff too large.\n         * For proper NFS, we'd use more sophisticated polynomial selection.\n         * For this simplified version, just ensure it works. */\n    }\n\n    /* Verify: f(m) = N */\n    mpz_t check;\n    mpz_init(check);\n    mpz_set(check, poly_coeff[degree]);\n    for (int i = degree - 1; i >= 0; i--) {\n        mpz_mul(check, check, poly_m);\n        mpz_add(check, check, poly_coeff[i]);\n    }\n    if (mpz_cmp(check, gN) != 0) {\n        gmp_fprintf(stderr, \"SNFS: polynomial verification FAILED: f(m)=%Zd != N=%Zd\\n\", check, gN);\n        /* Try fixing by adjusting the leading coefficient */\n        mpz_sub(check, gN, check);\n        /* check = N - f(m). Need to add check to some coefficient. */\n        /* Add to c_0 (constant term): new f(m) = old f(m) + check */\n        mpz_add(poly_coeff[0], poly_coeff[0], check);\n    }\n    mpz_clear(check);\n    mpz_clear(rem);\n    mpz_clear(base);\n\n    fprintf(stderr, \"SNFS: degree %d, m=\", poly_deg);\n    mpz_out_str(stderr, 10, poly_m);\n    fprintf(stderr, \"\\nSNFS: coefficients: \");\n    for (int i = poly_deg; i >= 0; i--) {\n        mpz_out_str(stderr, 10, poly_coeff[i]);\n        if (i > 0) fprintf(stderr, \" \");\n    }\n    fprintf(stderr, \"\\n\");\n}\n\n/* Evaluate polynomial f(x) using mpz */\nstatic void eval_poly(mpz_t result, long a, long b) {\n    /* Compute b^d * f(a/b) = c_d * a^d + c_{d-1} * a^{d-1} * b + ... + c_0 * b^d\n     * This is the algebraic norm (homogeneous evaluation) */\n    mpz_t term, a_pow, b_pow, temp;\n    mpz_init(term); mpz_init(a_pow); mpz_init(b_pow); mpz_init(temp);\n\n    mpz_set_ui(result, 0);\n    mpz_set_si(a_pow, 1);\n    /* Start from constant term (i=0) */\n    /* For i=0: c_0 * a^0 * b^d = c_0 * b^d */\n    /* For i=d: c_d * a^d * b^0 = c_d * a^d */\n\n    /* Horner's method in a, with b scaling:\n     * f_hom(a,b) = c_d*a^d + c_{d-1}*a^{d-1}*b + ... + c_0*b^d\n     * = a * (c_d*a^{d-1} + c_{d-1}*a^{d-2}*b + ...) + c_0*b^d\n     * Better: use Horner directly */\n\n    /* Horner: result = c_d */\n    mpz_set(result, poly_coeff[poly_deg]);\n    for (int i = poly_deg - 1; i >= 0; i--) {\n        /* result = result * a + c_i * b^(d-i) */\n        /* Actually for homogeneous: result = result * a + c_i * b^{step} */\n        /* Let me just compute directly */\n    }\n\n    /* Direct computation is simpler for low degree */\n    mpz_set_ui(result, 0);\n    for (int i = 0; i <= poly_deg; i++) {\n        /* term = c_i * a^i * b^(d-i) */\n        mpz_set(term, poly_coeff[i]);\n\n        /* Multiply by a^i */\n        for (int j = 0; j < i; j++) {\n            mpz_mul_si(term, term, a);\n        }\n        /* Multiply by b^(d-i) */\n        for (int j = 0; j < poly_deg - i; j++) {\n            mpz_mul_si(term, term, b);\n        }\n\n        mpz_add(result, result, term);\n    }\n\n    mpz_clear(term); mpz_clear(a_pow); mpz_clear(b_pow); mpz_clear(temp);\n}\n\n/* Compute rational side value: a - b*m */\nstatic void eval_rational(mpz_t result, long a, long b) {\n    mpz_set_si(result, a);\n    mpz_t bm;\n    mpz_init(bm);\n    mpz_mul_si(bm, poly_m, b);\n    mpz_sub(result, result, bm);\n    mpz_clear(bm);\n}\n\n/* Build factor bases */\nstatic void build_factor_bases(int target_size) {\n    rat_fb_size = 0;\n    alg_fb_size = 0;\n\n    /* Rational FB: primes p where p doesn't divide leading coefficient\n     * and N is QR mod p (or p divides N) */\n    /* Actually for NFS, rational FB is just all small primes */\n    for (unsigned long p = 2; rat_fb_size < target_size; p++) {\n        if (!is_prime(p)) continue;\n        rat_fb[rat_fb_size++] = p;\n    }\n\n    /* Algebraic FB: primes p where f has a root mod p */\n    for (unsigned long p = 2; alg_fb_size < target_size && p < 1000000; p++) {\n        if (!is_prime(p)) continue;\n\n        /* Check if f has a root mod p */\n        unsigned long pm = p;\n        for (unsigned long r = 0; r < pm; r++) {\n            /* Evaluate f(r) mod p */\n            unsigned long val = 0;\n            unsigned long r_pow = 1;\n            for (int i = 0; i <= poly_deg; i++) {\n                long ci = mpz_fdiv_ui(poly_coeff[i], p);\n                val = (val + (__uint128_t)ci * r_pow) % p;\n                r_pow = (__uint128_t)r_pow * r % p;\n            }\n            if (val == 0) {\n                alg_fb[alg_fb_size] = p;\n                alg_fb_roots[alg_fb_size] = (int)r;\n                alg_fb_size++;\n                if (alg_fb_size >= target_size) break;\n                /* For degree d, there can be up to d roots mod p.\n                 * We should record all of them. For simplicity, just take the first. */\n                break; /* take only first root for now */\n            }\n        }\n    }\n\n    /* Target: need enough relations to span both factor bases + extra */\n    target_rels = rat_fb_size + alg_fb_size + 64;\n    fprintf(stderr, \"SNFS: rational FB=%d (up to %lu), algebraic FB=%d, need %d rels\\n\",\n            rat_fb_size, rat_fb[rat_fb_size-1], alg_fb_size, target_rels);\n}\n\n/* Trial divide a value by a factor base. Returns 1 if smooth. */\nstatic int trial_div_fb(mpz_t val, unsigned long *fb, int fb_size,\n                        unsigned long *exps, mpz_t cofactor) {\n    mpz_abs(cofactor, val);\n    memset(exps, 0, fb_size * sizeof(unsigned long));\n\n    for (int i = 0; i < fb_size; i++) {\n        while (mpz_divisible_ui_p(cofactor, fb[i])) {\n            exps[i]++;\n            mpz_divexact_ui(cofactor, cofactor, fb[i]);\n        }\n    }\n    return mpz_cmp_ui(cofactor, 1) == 0;\n}\n\n/* Main NFS sieve: enumerate (a,b) pairs and check double smoothness */\nstatic void nfs_enumerate(void) {\n    mpz_t rat_val, alg_val, rat_cof, alg_cof;\n    mpz_init(rat_val); mpz_init(alg_val); mpz_init(rat_cof); mpz_init(alg_cof);\n\n    unsigned long *rat_exps = calloc(rat_fb_size, sizeof(unsigned long));\n    unsigned long *alg_exps = calloc(alg_fb_size, sizeof(unsigned long));\n\n    int exp_total = rat_fb_size + alg_fb_size + 2; /* +2 for signs */\n    int exp_bytes = (exp_total + 7) / 8;\n\n    int checked = 0, found = 0;\n    int max_a = 10000000, max_b = 1000;\n\n    for (int b = 1; b <= max_b && nrels < target_rels; b++) {\n        for (int a = -max_a; a <= max_a && nrels < target_rels; a++) {\n            if (a == 0) continue;\n            /* gcd(a, b) must be 1 */\n            int g = a < 0 ? -a : a;\n            { int t = b; while (t) { int r = g % t; g = t; t = r; } }\n            if (g != 1) continue;\n\n            if (walltime() - gStart > 285.0) goto done;\n\n            /* Rational side: a - b*m */\n            eval_rational(rat_val, a, b);\n            if (mpz_sgn(rat_val) == 0) continue;\n\n            /* Quick check: is rational value small enough to possibly be smooth? */\n            int rat_bits = mpz_sizeinbase(rat_val, 2);\n\n            /* Trial divide rational side */\n            int rat_smooth = trial_div_fb(rat_val, rat_fb, rat_fb_size,\n                                          rat_exps, rat_cof);\n            if (!rat_smooth) {\n                /* Allow 1 large prime on rational side */\n                if (mpz_sizeinbase(rat_cof, 2) > 30) continue;\n            }\n\n            checked++;\n\n            /* Algebraic side: homogeneous f(a, b) */\n            eval_alg:\n            eval_poly(alg_val, a, b);\n            if (mpz_sgn(alg_val) == 0) continue;\n\n            int alg_smooth = trial_div_fb(alg_val, alg_fb, alg_fb_size,\n                                          alg_exps, alg_cof);\n            if (!alg_smooth) {\n                if (mpz_sizeinbase(alg_cof, 2) > 30) continue;\n            }\n\n            /* DOUBLE SMOOTH! (or both with small cofactors) */\n            if (rat_smooth && alg_smooth) {\n                /* Full relation */\n                rel_t *r = &rels[nrels];\n                r->a = a; r->b = b;\n                r->exp = calloc(exp_bytes, 1);\n                r->full_exp = calloc(exp_total, sizeof(unsigned long));\n                mpz_init(r->x_rat);\n                mpz_set(r->x_rat, rat_val);\n\n                /* Pack exponents: [rat_sign, rat_fb..., alg_sign, alg_fb...] */\n                int offset = 0;\n                /* Rational sign */\n                if (mpz_sgn(rat_val) < 0) {\n                    r->exp[0] |= 1;\n                    r->full_exp[0] = 1;\n                }\n                offset = 1;\n                /* Rational FB */\n                for (int i = 0; i < rat_fb_size; i++) {\n                    r->full_exp[offset + i] = rat_exps[i];\n                    if (rat_exps[i] & 1)\n                        r->exp[(offset + i) / 8] |= (1 << ((offset + i) % 8));\n                }\n                offset += rat_fb_size;\n                /* Algebraic sign */\n                if (mpz_sgn(alg_val) < 0) {\n                    r->exp[offset / 8] |= (1 << (offset % 8));\n                    r->full_exp[offset] = 1;\n                }\n                offset++;\n                /* Algebraic FB */\n                for (int i = 0; i < alg_fb_size; i++) {\n                    r->full_exp[offset + i] = alg_exps[i];\n                    if (alg_exps[i] & 1)\n                        r->exp[(offset + i) / 8] |= (1 << ((offset + i) % 8));\n                }\n\n                nrels++;\n                found++;\n\n                if (found % 50 == 0 || found < 10) {\n                    fprintf(stderr, \"SNFS: [%.1fs] found %d/%d rels (checked %d, a=%d b=%d)\\n\",\n                            walltime() - gStart, found, target_rels, checked, a, b);\n                }\n            }\n        }\n    }\n\n    done:\n    free(rat_exps); free(alg_exps);\n    mpz_clear(rat_val); mpz_clear(alg_val); mpz_clear(rat_cof); mpz_clear(alg_cof);\n}\n\n/* GF(2) linear algebra and factor extraction */\nstatic int solve_nfs(mpz_t result) {\n    int n = nrels;\n    int m = rat_fb_size + alg_fb_size + 2; /* total columns */\n\n    if (n < m + 1) return 0;\n\n    fprintf(stderr, \"SNFS: solving %d x %d matrix\\n\", n, m);\n\n    int words = (m + n + 63) / 64;\n    unsigned long *mat = calloc((size_t)n * words, sizeof(unsigned long));\n\n    #define MGET(r, c) ((mat[(size_t)(r) * words + (c)/64] >> ((c) % 64)) & 1)\n    #define MSET(r, c) (mat[(size_t)(r) * words + (c)/64] |= (1UL << ((c) % 64)))\n    #define MXOR(dst, src) do { for (int _w = 0; _w < words; _w++) \\\n        mat[(size_t)(dst)*words + _w] ^= mat[(size_t)(src)*words + _w]; } while(0)\n\n    for (int i = 0; i < n; i++) {\n        int exp_bits = m;\n        int exp_bytes = (exp_bits + 7) / 8;\n        for (int j = 0; j < exp_bits; j++) {\n            if ((rels[i].exp[j/8] >> (j%8)) & 1)\n                MSET(i, j);\n        }\n        MSET(i, m + i);\n    }\n\n    /* Gaussian elimination */\n    int rank = 0;\n    for (int j = 0; j < m && rank < n; j++) {\n        int piv = -1;\n        for (int i = rank; i < n; i++)\n            if (MGET(i, j)) { piv = i; break; }\n        if (piv < 0) continue;\n        if (piv != rank) {\n            for (int w = 0; w < words; w++) {\n                unsigned long t = mat[(size_t)rank * words + w];\n                mat[(size_t)rank * words + w] = mat[(size_t)piv * words + w];\n                mat[(size_t)piv * words + w] = t;\n            }\n        }\n        for (int i = 0; i < n; i++) {\n            if (i != rank && MGET(i, j)) MXOR(i, rank);\n        }\n        rank++;\n    }\n\n    fprintf(stderr, \"SNFS: rank=%d, %d null vectors\\n\", rank, n - rank);\n\n    /* For NFS, the square root step is more complex than QS.\n     * Simplified approach: for each null vector, compute:\n     * - Product of (a - b*m) on rational side → square → take sqrt mod N\n     * - Product of algebraic norms → need algebraic square root\n     *\n     * For now, use a simplified approach that works for some null vectors:\n     * Compute x = product of (a_i - b_i * m) mod N\n     * Compute y = product of sqrt(algebraic norms) mod N\n     * gcd(x - y, N) */\n\n    /* Actually, for the simplified version:\n     * Each relation gives (a - bm) is smooth on both sides.\n     * The product of (a - bm) values for a null vector is a perfect square\n     * on the RATIONAL side. We need to compute the algebraic square root too.\n     *\n     * For now, just use the rational side: compute the product of\n     * (a - b*m) values mod N, and the product of their prime factorizations.\n     * This gives x^2 ≡ y^2 (mod N) on the rational side alone. */\n\n    mpz_t X, Y, g, tmp;\n    mpz_init(X); mpz_init(Y); mpz_init(g); mpz_init(tmp);\n    int found = 0;\n\n    for (int row = rank; row < n && !found; row++) {\n        mpz_set_ui(X, 1);\n        unsigned long *tot = calloc(m, sizeof(unsigned long));\n        int count = 0;\n\n        for (int i = 0; i < n; i++) {\n            if (!MGET(row, m + i)) continue;\n            count++;\n\n            /* X *= (a_i - b_i * m) mod N */\n            mpz_t rat;\n            mpz_init(rat);\n            eval_rational(rat, rels[i].a, rels[i].b);\n            mpz_mul(X, X, rat);\n            mpz_mod(X, X, gN);\n            mpz_clear(rat);\n\n            for (int k = 0; k < m; k++)\n                tot[k] += rels[i].full_exp[k];\n        }\n\n        if (count == 0) { free(tot); continue; }\n\n        /* Compute Y = product of rational primes^(exp/2) mod N */\n        mpz_set_ui(Y, 1);\n        int offset = 1; /* skip sign */\n        for (int k = 0; k < rat_fb_size; k++) {\n            if (tot[offset + k] == 0) continue;\n            unsigned long half = tot[offset + k] / 2;\n            if (half == 0) continue;\n            mpz_set_ui(tmp, rat_fb[k]);\n            mpz_powm_ui(tmp, tmp, half, gN);\n            mpz_mul(Y, Y, tmp);\n            mpz_mod(Y, Y, gN);\n        }\n\n        /* NOTE: This simplified approach only uses the rational side.\n         * For a complete NFS, we'd also need the algebraic square root.\n         * The rational-side-only approach works when the rational side alone\n         * gives a congruence of squares, which happens when the exponents\n         * on the rational side are all even. This is a subset of the full\n         * null space but still works. */\n\n        /* Check that rational exponents are all even */\n        int rational_ok = 1;\n        if (tot[0] & 1) rational_ok = 0; /* sign */\n        for (int k = 0; k < rat_fb_size; k++) {\n            if (tot[offset + k] & 1) { rational_ok = 0; break; }\n        }\n\n        if (!rational_ok) { free(tot); continue; }\n\n        mpz_sub(tmp, X, Y);\n        mpz_gcd(g, tmp, gN);\n        if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {\n            mpz_set(result, g);\n            found = 1;\n        }\n        if (!found) {\n            mpz_add(tmp, X, Y);\n            mpz_gcd(g, tmp, gN);\n            if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {\n                mpz_set(result, g);\n                found = 1;\n            }\n        }\n\n        free(tot);\n    }\n\n    mpz_clear(X); mpz_clear(Y); mpz_clear(g); mpz_clear(tmp);\n    free(mat);\n    return found;\n\n    #undef MGET\n    #undef MSET\n    #undef MXOR\n}\n\nint main(int argc, char *argv[]) {\n    if (argc < 2) { fprintf(stderr, \"Usage: %s <N>\\n\", argv[0]); return 1; }\n\n    gStart = walltime();\n    mpz_init(gN);\n    mpz_set_str(gN, argv[1], 10);\n    int digits = strlen(argv[1]);\n\n    if (mpz_probab_prime_p(gN, 25)) {\n        fprintf(stderr, \"N is prime\\n\");\n        return 1;\n    }\n\n    /* Trial division */\n    for (unsigned long p = 2; p < 1000000; p++) {\n        if (mpz_divisible_ui_p(gN, p)) {\n            printf(\"FACTOR: %lu\\n\", p);\n            return 0;\n        }\n    }\n\n    /* Choose polynomial degree based on N size */\n    int degree;\n    if (digits <= 40) degree = 3;\n    else if (digits <= 60) degree = 4;\n    else degree = 5;\n\n    fprintf(stderr, \"SNFS: %d-digit N, degree %d\\n\", digits, degree);\n\n    /* Select polynomial */\n    select_polynomial(degree);\n\n    /* Build factor bases */\n    /* For simplified NFS: smaller FB than standard NFS, relying on\n     * smaller norm values to compensate */\n    int fb_target;\n    {\n        double lnN = digits * 2.302585;\n        double lnlnN = log(lnN);\n        double B = exp(0.4 * sqrt(lnN * lnlnN)); /* slightly smaller than QS */\n        fb_target = (int)(B / log(B));\n        if (fb_target < 30) fb_target = 30;\n        if (fb_target > 2000) fb_target = 2000;\n    }\n\n    build_factor_bases(fb_target);\n\n    /* Enumerate (a,b) pairs and collect doubly-smooth relations */\n    nfs_enumerate();\n\n    fprintf(stderr, \"SNFS: collected %d relations\\n\", nrels);\n\n    /* Solve */\n    if (nrels >= target_rels / 2) { /* try even with fewer relations */\n        mpz_t factor;\n        mpz_init(factor);\n        if (solve_nfs(factor)) {\n            mpz_t cof;\n            mpz_init(cof);\n            mpz_divexact(cof, gN, factor);\n            if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n            gmp_printf(\"FACTOR: %Zd\\n\", factor);\n            fprintf(stderr, \"SNFS: done in %.2fs\\n\", walltime() - gStart);\n            mpz_clear(cof); mpz_clear(factor);\n            return 0;\n        }\n        mpz_clear(factor);\n    }\n\n    /* Fallback: ECM */\n    fprintf(stderr, \"SNFS: falling back to ECM\\n\");\n    {\n        ecm_params params;\n        ecm_init(params);\n        params->param = ECM_PARAM_SUYAMA;\n        mpz_t factor;\n        mpz_init(factor);\n        double b1s[] = {2000, 11000, 50000, 250000, 1e6, 3e6, 11e6, 44e6};\n        int curves[] = {25, 50, 100, 200, 400, 700, 1200, 2400};\n        for (int lev = 0; lev < 8; lev++) {\n            for (int c = 0; c < curves[lev]; c++) {\n                if (walltime() - gStart > 290.0) goto done2;\n                mpz_set_ui(factor, 0);\n                params->B1done = 1.0;\n                mpz_set_ui(params->sigma, 42 + lev * 10000 + c);\n                int ret = ecm_factor(factor, gN, b1s[lev], params);\n                if (ret > 0 && mpz_cmp_ui(factor, 1) > 0 && mpz_cmp(factor, gN) < 0) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    mpz_clear(cof);\n                    ecm_clear(params); mpz_clear(factor);\n                    return 0;\n                }\n            }\n        }\n        done2:\n        ecm_clear(params); mpz_clear(factor);\n    }\n\n    fprintf(stderr, \"SNFS: failed\\n\");\n    return 1;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":454,"cache_read_input_tokens":209312,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":454},"output_tokens":54,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f16ee78b-ee57-47d2-a561-91e9aefa955b","uuid":"dacc20ef-6b06-4c7f-be7f-8d0b0e2bc747"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Ed5HyKPKjSnR2fYJHH8zC","type":"tool_result","content":"File created successfully at: /tmp/agent-factoring-3/library/snfs_lite.c"}]},"parent_tool_use_id":null,"session_id":"f16ee78b-ee57-47d2-a561-91e9aefa955b","uuid":"14cbf4f7-cb2f-4239-954d-799bbc601aee","timestamp":"2026-03-24T02:56:00.709Z","tool_use_result":{"type":"create","filePath":"/tmp/agent-factoring-3/library/snfs_lite.c","content":"/*\n * snfs_lite.c — Simplified Number Field Sieve for medium-sized numbers\n *\n * Novel approach: apply NFS-style algebraic norm reduction to numbers\n * in the 40-80 digit range, where standard NFS is normally considered\n * too heavyweight. Uses:\n * 1. Base-m polynomial construction (no special form needed)\n * 2. Brute-force (a,b) evaluation (no lattice sieving)\n * 3. Trial division for smoothness on both sides\n * 4. Standard GF(2) linear algebra\n *\n * The key hypothesis: even with brute-force evaluation (no lattice sieve),\n * the smaller algebraic norm values (~N^{1/3} vs ~N^{1/2} for QS) might\n * compensate for the double-smoothness requirement, giving better scaling\n * for medium-sized numbers.\n *\n * Usage: ./snfs_lite <N>\n * Output: FACTOR: <p>\n */\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <math.h>\n#include <time.h>\n#include <gmp.h>\n#include <ecm.h>\n\n#define MAX_FB 8192\n#define MAX_RELS (MAX_FB + 512)\n\ntypedef struct {\n    int a;           /* rational coefficient */\n    int b;           /* algebraic coefficient */\n    /* Relation: (a - b*m)^2 or more precisely:\n     * rat_val = a - b*m\n     * alg_val = b^d * f(a/b) = resultant_like algebraic norm\n     * We need both to be smooth. */\n} candidate_t;\n\ntypedef struct {\n    int a, b;\n    unsigned char *exp;       /* GF(2) exponent vector for both sides */\n    unsigned long *full_exp;  /* full exponents for square root */\n    mpz_t x_rat;              /* x value for rational side */\n} rel_t;\n\n/* Polynomial f(x) = c_d * x^d + ... + c_0 with f(m) ≡ 0 (mod N) */\nstatic int poly_deg;\nstatic mpz_t poly_coeff[8]; /* up to degree 7 */\nstatic mpz_t poly_m;        /* m such that f(m) ≡ 0 (mod N) */\nstatic mpz_t gN;\n\n/* Factor bases */\nstatic unsigned long rat_fb[MAX_FB]; /* rational factor base primes */\nstatic int rat_fb_size = 0;\nstatic unsigned long alg_fb[MAX_FB]; /* algebraic factor base (prime, root) pairs */\nstatic int alg_fb_roots[MAX_FB];     /* root of f mod p */\nstatic int alg_fb_size = 0;\n\nstatic rel_t rels[MAX_RELS];\nstatic int nrels = 0;\nstatic int target_rels = 0;\nstatic double gStart;\n\nstatic double walltime(void) {\n    struct timespec ts;\n    clock_gettime(CLOCK_MONOTONIC, &ts);\n    return ts.tv_sec + ts.tv_nsec * 1e-9;\n}\n\nstatic int is_prime(unsigned long n) {\n    if (n < 2) return 0;\n    if (n < 4) return 1;\n    if (n % 2 == 0 || n % 3 == 0) return 0;\n    for (unsigned long d = 5; d * d <= n; d += 6)\n        if (n % d == 0 || n % (d+2) == 0) return 0;\n    return 1;\n}\n\n/* Polynomial selection: base-m method\n * Write N in base m: N = c_d * m^d + c_{d-1} * m^{d-1} + ... + c_0\n * Then f(x) = c_d * x^d + ... + c_0 and f(m) = N. */\nstatic void select_polynomial(int degree) {\n    poly_deg = degree;\n    for (int i = 0; i <= degree; i++)\n        mpz_init(poly_coeff[i]);\n    mpz_init(poly_m);\n\n    /* m = floor(N^{1/(d+1)}) approximately */\n    /* For degree d, optimal m ≈ N^{1/(d+1)} */\n    mpz_t rem, base;\n    mpz_init(rem);\n    mpz_init(base);\n\n    /* Compute m = floor(N^(1/(d+1))) */\n    mpz_root(poly_m, gN, degree + 1);\n    /* Adjust slightly for better coefficients */\n    /* Try m, m+1, m-1 and pick the one with smallest max coefficient */\n\n    mpz_set(rem, gN);\n    /* Extract digits in base m */\n    for (int i = 0; i <= degree; i++) {\n        mpz_tdiv_qr(rem, poly_coeff[i], rem, poly_m);\n    }\n    /* rem should be 0 if m is chosen perfectly, or small otherwise */\n    /* For the leading coefficient, it's whatever's left in rem */\n    if (mpz_sgn(rem) != 0) {\n        /* Not perfectly base-m representable — use the last coeff + rem */\n        mpz_addmul(poly_coeff[degree], rem, poly_m);\n        /* Actually, let's redo: just divide N by m repeatedly */\n    }\n\n    /* Redo: proper base-m decomposition */\n    mpz_set(rem, gN);\n    for (int i = 0; i <= degree; i++) {\n        mpz_fdiv_qr(rem, poly_coeff[i], rem, poly_m);\n    }\n    /* The remaining 'rem' should be 0 or we add it to the top coefficient */\n    if (mpz_sgn(rem) != 0) {\n        /* Leading coefficient absorbs remainder */\n        mpz_add(poly_coeff[degree], poly_coeff[degree], rem);\n        /* But this might make the leading coeff too large.\n         * For proper NFS, we'd use more sophisticated polynomial selection.\n         * For this simplified version, just ensure it works. */\n    }\n\n    /* Verify: f(m) = N */\n    mpz_t check;\n    mpz_init(check);\n    mpz_set(check, poly_coeff[degree]);\n    for (int i = degree - 1; i >= 0; i--) {\n        mpz_mul(check, check, poly_m);\n        mpz_add(check, check, poly_coeff[i]);\n    }\n    if (mpz_cmp(check, gN) != 0) {\n        gmp_fprintf(stderr, \"SNFS: polynomial verification FAILED: f(m)=%Zd != N=%Zd\\n\", check, gN);\n        /* Try fixing by adjusting the leading coefficient */\n        mpz_sub(check, gN, check);\n        /* check = N - f(m). Need to add check to some coefficient. */\n        /* Add to c_0 (constant term): new f(m) = old f(m) + check */\n        mpz_add(poly_coeff[0], poly_coeff[0], check);\n    }\n    mpz_clear(check);\n    mpz_clear(rem);\n    mpz_clear(base);\n\n    fprintf(stderr, \"SNFS: degree %d, m=\", poly_deg);\n    mpz_out_str(stderr, 10, poly_m);\n    fprintf(stderr, \"\\nSNFS: coefficients: \");\n    for (int i = poly_deg; i >= 0; i--) {\n        mpz_out_str(stderr, 10, poly_coeff[i]);\n        if (i > 0) fprintf(stderr, \" \");\n    }\n    fprintf(stderr, \"\\n\");\n}\n\n/* Evaluate polynomial f(x) using mpz */\nstatic void eval_poly(mpz_t result, long a, long b) {\n    /* Compute b^d * f(a/b) = c_d * a^d + c_{d-1} * a^{d-1} * b + ... + c_0 * b^d\n     * This is the algebraic norm (homogeneous evaluation) */\n    mpz_t term, a_pow, b_pow, temp;\n    mpz_init(term); mpz_init(a_pow); mpz_init(b_pow); mpz_init(temp);\n\n    mpz_set_ui(result, 0);\n    mpz_set_si(a_pow, 1);\n    /* Start from constant term (i=0) */\n    /* For i=0: c_0 * a^0 * b^d = c_0 * b^d */\n    /* For i=d: c_d * a^d * b^0 = c_d * a^d */\n\n    /* Horner's method in a, with b scaling:\n     * f_hom(a,b) = c_d*a^d + c_{d-1}*a^{d-1}*b + ... + c_0*b^d\n     * = a * (c_d*a^{d-1} + c_{d-1}*a^{d-2}*b + ...) + c_0*b^d\n     * Better: use Horner directly */\n\n    /* Horner: result = c_d */\n    mpz_set(result, poly_coeff[poly_deg]);\n    for (int i = poly_deg - 1; i >= 0; i--) {\n        /* result = result * a + c_i * b^(d-i) */\n        /* Actually for homogeneous: result = result * a + c_i * b^{step} */\n        /* Let me just compute directly */\n    }\n\n    /* Direct computation is simpler for low degree */\n    mpz_set_ui(result, 0);\n    for (int i = 0; i <= poly_deg; i++) {\n        /* term = c_i * a^i * b^(d-i) */\n        mpz_set(term, poly_coeff[i]);\n\n        /* Multiply by a^i */\n        for (int j = 0; j < i; j++) {\n            mpz_mul_si(term, term, a);\n        }\n        /* Multiply by b^(d-i) */\n        for (int j = 0; j < poly_deg - i; j++) {\n            mpz_mul_si(term, term, b);\n        }\n\n        mpz_add(result, result, term);\n    }\n\n    mpz_clear(term); mpz_clear(a_pow); mpz_clear(b_pow); mpz_clear(temp);\n}\n\n/* Compute rational side value: a - b*m */\nstatic void eval_rational(mpz_t result, long a, long b) {\n    mpz_set_si(result, a);\n    mpz_t bm;\n    mpz_init(bm);\n    mpz_mul_si(bm, poly_m, b);\n    mpz_sub(result, result, bm);\n    mpz_clear(bm);\n}\n\n/* Build factor bases */\nstatic void build_factor_bases(int target_size) {\n    rat_fb_size = 0;\n    alg_fb_size = 0;\n\n    /* Rational FB: primes p where p doesn't divide leading coefficient\n     * and N is QR mod p (or p divides N) */\n    /* Actually for NFS, rational FB is just all small primes */\n    for (unsigned long p = 2; rat_fb_size < target_size; p++) {\n        if (!is_prime(p)) continue;\n        rat_fb[rat_fb_size++] = p;\n    }\n\n    /* Algebraic FB: primes p where f has a root mod p */\n    for (unsigned long p = 2; alg_fb_size < target_size && p < 1000000; p++) {\n        if (!is_prime(p)) continue;\n\n        /* Check if f has a root mod p */\n        unsigned long pm = p;\n        for (unsigned long r = 0; r < pm; r++) {\n            /* Evaluate f(r) mod p */\n            unsigned long val = 0;\n            unsigned long r_pow = 1;\n            for (int i = 0; i <= poly_deg; i++) {\n                long ci = mpz_fdiv_ui(poly_coeff[i], p);\n                val = (val + (__uint128_t)ci * r_pow) % p;\n                r_pow = (__uint128_t)r_pow * r % p;\n            }\n            if (val == 0) {\n                alg_fb[alg_fb_size] = p;\n                alg_fb_roots[alg_fb_size] = (int)r;\n                alg_fb_size++;\n                if (alg_fb_size >= target_size) break;\n                /* For degree d, there can be up to d roots mod p.\n                 * We should record all of them. For simplicity, just take the first. */\n                break; /* take only first root for now */\n            }\n        }\n    }\n\n    /* Target: need enough relations to span both factor bases + extra */\n    target_rels = rat_fb_size + alg_fb_size + 64;\n    fprintf(stderr, \"SNFS: rational FB=%d (up to %lu), algebraic FB=%d, need %d rels\\n\",\n            rat_fb_size, rat_fb[rat_fb_size-1], alg_fb_size, target_rels);\n}\n\n/* Trial divide a value by a factor base. Returns 1 if smooth. */\nstatic int trial_div_fb(mpz_t val, unsigned long *fb, int fb_size,\n                        unsigned long *exps, mpz_t cofactor) {\n    mpz_abs(cofactor, val);\n    memset(exps, 0, fb_size * sizeof(unsigned long));\n\n    for (int i = 0; i < fb_size; i++) {\n        while (mpz_divisible_ui_p(cofactor, fb[i])) {\n            exps[i]++;\n            mpz_divexact_ui(cofactor, cofactor, fb[i]);\n        }\n    }\n    return mpz_cmp_ui(cofactor, 1) == 0;\n}\n\n/* Main NFS sieve: enumerate (a,b) pairs and check double smoothness */\nstatic void nfs_enumerate(void) {\n    mpz_t rat_val, alg_val, rat_cof, alg_cof;\n    mpz_init(rat_val); mpz_init(alg_val); mpz_init(rat_cof); mpz_init(alg_cof);\n\n    unsigned long *rat_exps = calloc(rat_fb_size, sizeof(unsigned long));\n    unsigned long *alg_exps = calloc(alg_fb_size, sizeof(unsigned long));\n\n    int exp_total = rat_fb_size + alg_fb_size + 2; /* +2 for signs */\n    int exp_bytes = (exp_total + 7) / 8;\n\n    int checked = 0, found = 0;\n    int max_a = 10000000, max_b = 1000;\n\n    for (int b = 1; b <= max_b && nrels < target_rels; b++) {\n        for (int a = -max_a; a <= max_a && nrels < target_rels; a++) {\n            if (a == 0) continue;\n            /* gcd(a, b) must be 1 */\n            int g = a < 0 ? -a : a;\n            { int t = b; while (t) { int r = g % t; g = t; t = r; } }\n            if (g != 1) continue;\n\n            if (walltime() - gStart > 285.0) goto done;\n\n            /* Rational side: a - b*m */\n            eval_rational(rat_val, a, b);\n            if (mpz_sgn(rat_val) == 0) continue;\n\n            /* Quick check: is rational value small enough to possibly be smooth? */\n            int rat_bits = mpz_sizeinbase(rat_val, 2);\n\n            /* Trial divide rational side */\n            int rat_smooth = trial_div_fb(rat_val, rat_fb, rat_fb_size,\n                                          rat_exps, rat_cof);\n            if (!rat_smooth) {\n                /* Allow 1 large prime on rational side */\n                if (mpz_sizeinbase(rat_cof, 2) > 30) continue;\n            }\n\n            checked++;\n\n            /* Algebraic side: homogeneous f(a, b) */\n            eval_alg:\n            eval_poly(alg_val, a, b);\n            if (mpz_sgn(alg_val) == 0) continue;\n\n            int alg_smooth = trial_div_fb(alg_val, alg_fb, alg_fb_size,\n                                          alg_exps, alg_cof);\n            if (!alg_smooth) {\n                if (mpz_sizeinbase(alg_cof, 2) > 30) continue;\n            }\n\n            /* DOUBLE SMOOTH! (or both with small cofactors) */\n            if (rat_smooth && alg_smooth) {\n                /* Full relation */\n                rel_t *r = &rels[nrels];\n                r->a = a; r->b = b;\n                r->exp = calloc(exp_bytes, 1);\n                r->full_exp = calloc(exp_total, sizeof(unsigned long));\n                mpz_init(r->x_rat);\n                mpz_set(r->x_rat, rat_val);\n\n                /* Pack exponents: [rat_sign, rat_fb..., alg_sign, alg_fb...] */\n                int offset = 0;\n                /* Rational sign */\n                if (mpz_sgn(rat_val) < 0) {\n                    r->exp[0] |= 1;\n                    r->full_exp[0] = 1;\n                }\n                offset = 1;\n                /* Rational FB */\n                for (int i = 0; i < rat_fb_size; i++) {\n                    r->full_exp[offset + i] = rat_exps[i];\n                    if (rat_exps[i] & 1)\n                        r->exp[(offset + i) / 8] |= (1 << ((offset + i) % 8));\n                }\n                offset += rat_fb_size;\n                /* Algebraic sign */\n                if (mpz_sgn(alg_val) < 0) {\n                    r->exp[offset / 8] |= (1 << (offset % 8));\n                    r->full_exp[offset] = 1;\n                }\n                offset++;\n                /* Algebraic FB */\n                for (int i = 0; i < alg_fb_size; i++) {\n                    r->full_exp[offset + i] = alg_exps[i];\n                    if (alg_exps[i] & 1)\n                        r->exp[(offset + i) / 8] |= (1 << ((offset + i) % 8));\n                }\n\n                nrels++;\n                found++;\n\n                if (found % 50 == 0 || found < 10) {\n                    fprintf(stderr, \"SNFS: [%.1fs] found %d/%d rels (checked %d, a=%d b=%d)\\n\",\n                            walltime() - gStart, found, target_rels, checked, a, b);\n                }\n            }\n        }\n    }\n\n    done:\n    free(rat_exps); free(alg_exps);\n    mpz_clear(rat_val); mpz_clear(alg_val); mpz_clear(rat_cof); mpz_clear(alg_cof);\n}\n\n/* GF(2) linear algebra and factor extraction */\nstatic int solve_nfs(mpz_t result) {\n    int n = nrels;\n    int m = rat_fb_size + alg_fb_size + 2; /* total columns */\n\n    if (n < m + 1) return 0;\n\n    fprintf(stderr, \"SNFS: solving %d x %d matrix\\n\", n, m);\n\n    int words = (m + n + 63) / 64;\n    unsigned long *mat = calloc((size_t)n * words, sizeof(unsigned long));\n\n    #define MGET(r, c) ((mat[(size_t)(r) * words + (c)/64] >> ((c) % 64)) & 1)\n    #define MSET(r, c) (mat[(size_t)(r) * words + (c)/64] |= (1UL << ((c) % 64)))\n    #define MXOR(dst, src) do { for (int _w = 0; _w < words; _w++) \\\n        mat[(size_t)(dst)*words + _w] ^= mat[(size_t)(src)*words + _w]; } while(0)\n\n    for (int i = 0; i < n; i++) {\n        int exp_bits = m;\n        int exp_bytes = (exp_bits + 7) / 8;\n        for (int j = 0; j < exp_bits; j++) {\n            if ((rels[i].exp[j/8] >> (j%8)) & 1)\n                MSET(i, j);\n        }\n        MSET(i, m + i);\n    }\n\n    /* Gaussian elimination */\n    int rank = 0;\n    for (int j = 0; j < m && rank < n; j++) {\n        int piv = -1;\n        for (int i = rank; i < n; i++)\n            if (MGET(i, j)) { piv = i; break; }\n        if (piv < 0) continue;\n        if (piv != rank) {\n            for (int w = 0; w < words; w++) {\n                unsigned long t = mat[(size_t)rank * words + w];\n                mat[(size_t)rank * words + w] = mat[(size_t)piv * words + w];\n                mat[(size_t)piv * words + w] = t;\n            }\n        }\n        for (int i = 0; i < n; i++) {\n            if (i != rank && MGET(i, j)) MXOR(i, rank);\n        }\n        rank++;\n    }\n\n    fprintf(stderr, \"SNFS: rank=%d, %d null vectors\\n\", rank, n - rank);\n\n    /* For NFS, the square root step is more complex than QS.\n     * Simplified approach: for each null vector, compute:\n     * - Product of (a - b*m) on rational side → square → take sqrt mod N\n     * - Product of algebraic norms → need algebraic square root\n     *\n     * For now, use a simplified approach that works for some null vectors:\n     * Compute x = product of (a_i - b_i * m) mod N\n     * Compute y = product of sqrt(algebraic norms) mod N\n     * gcd(x - y, N) */\n\n    /* Actually, for the simplified version:\n     * Each relation gives (a - bm) is smooth on both sides.\n     * The product of (a - bm) values for a null vector is a perfect square\n     * on the RATIONAL side. We need to compute the algebraic square root too.\n     *\n     * For now, just use the rational side: compute the product of\n     * (a - b*m) values mod N, and the product of their prime factorizations.\n     * This gives x^2 ≡ y^2 (mod N) on the rational side alone. */\n\n    mpz_t X, Y, g, tmp;\n    mpz_init(X); mpz_init(Y); mpz_init(g); mpz_init(tmp);\n    int found = 0;\n\n    for (int row = rank; row < n && !found; row++) {\n        mpz_set_ui(X, 1);\n        unsigned long *tot = calloc(m, sizeof(unsigned long));\n        int count = 0;\n\n        for (int i = 0; i < n; i++) {\n            if (!MGET(row, m + i)) continue;\n            count++;\n\n            /* X *= (a_i - b_i * m) mod N */\n            mpz_t rat;\n            mpz_init(rat);\n            eval_rational(rat, rels[i].a, rels[i].b);\n            mpz_mul(X, X, rat);\n            mpz_mod(X, X, gN);\n            mpz_clear(rat);\n\n            for (int k = 0; k < m; k++)\n                tot[k] += rels[i].full_exp[k];\n        }\n\n        if (count == 0) { free(tot); continue; }\n\n        /* Compute Y = product of rational primes^(exp/2) mod N */\n        mpz_set_ui(Y, 1);\n        int offset = 1; /* skip sign */\n        for (int k = 0; k < rat_fb_size; k++) {\n            if (tot[offset + k] == 0) continue;\n            unsigned long half = tot[offset + k] / 2;\n            if (half == 0) continue;\n            mpz_set_ui(tmp, rat_fb[k]);\n            mpz_powm_ui(tmp, tmp, half, gN);\n            mpz_mul(Y, Y, tmp);\n            mpz_mod(Y, Y, gN);\n        }\n\n        /* NOTE: This simplified approach only uses the rational side.\n         * For a complete NFS, we'd also need the algebraic square root.\n         * The rational-side-only approach works when the rational side alone\n         * gives a congruence of squares, which happens when the exponents\n         * on the rational side are all even. This is a subset of the full\n         * null space but still works. */\n\n        /* Check that rational exponents are all even */\n        int rational_ok = 1;\n        if (tot[0] & 1) rational_ok = 0; /* sign */\n        for (int k = 0; k < rat_fb_size; k++) {\n            if (tot[offset + k] & 1) { rational_ok = 0; break; }\n        }\n\n        if (!rational_ok) { free(tot); continue; }\n\n        mpz_sub(tmp, X, Y);\n        mpz_gcd(g, tmp, gN);\n        if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {\n            mpz_set(result, g);\n            found = 1;\n        }\n        if (!found) {\n            mpz_add(tmp, X, Y);\n            mpz_gcd(g, tmp, gN);\n            if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {\n                mpz_set(result, g);\n                found = 1;\n            }\n        }\n\n        free(tot);\n    }\n\n    mpz_clear(X); mpz_clear(Y); mpz_clear(g); mpz_clear(tmp);\n    free(mat);\n    return found;\n\n    #undef MGET\n    #undef MSET\n    #undef MXOR\n}\n\nint main(int argc, char *argv[]) {\n    if (argc < 2) { fprintf(stderr, \"Usage: %s <N>\\n\", argv[0]); return 1; }\n\n    gStart = walltime();\n    mpz_init(gN);\n    mpz_set_str(gN, argv[1], 10);\n    int digits = strlen(argv[1]);\n\n    if (mpz_probab_prime_p(gN, 25)) {\n        fprintf(stderr, \"N is prime\\n\");\n        return 1;\n    }\n\n    /* Trial division */\n    for (unsigned long p = 2; p < 1000000; p++) {\n        if (mpz_divisible_ui_p(gN, p)) {\n            printf(\"FACTOR: %lu\\n\", p);\n            return 0;\n        }\n    }\n\n    /* Choose polynomial degree based on N size */\n    int degree;\n    if (digits <= 40) degree = 3;\n    else if (digits <= 60) degree = 4;\n    else degree = 5;\n\n    fprintf(stderr, \"SNFS: %d-digit N, degree %d\\n\", digits, degree);\n\n    /* Select polynomial */\n    select_polynomial(degree);\n\n    /* Build factor bases */\n    /* For simplified NFS: smaller FB than standard NFS, relying on\n     * smaller norm values to compensate */\n    int fb_target;\n    {\n        double lnN = digits * 2.302585;\n        double lnlnN = log(lnN);\n        double B = exp(0.4 * sqrt(lnN * lnlnN)); /* slightly smaller than QS */\n        fb_target = (int)(B / log(B));\n        if (fb_target < 30) fb_target = 30;\n        if (fb_target > 2000) fb_target = 2000;\n    }\n\n    build_factor_bases(fb_target);\n\n    /* Enumerate (a,b) pairs and collect doubly-smooth relations */\n    nfs_enumerate();\n\n    fprintf(stderr, \"SNFS: collected %d relations\\n\", nrels);\n\n    /* Solve */\n    if (nrels >= target_rels / 2) { /* try even with fewer relations */\n        mpz_t factor;\n        mpz_init(factor);\n        if (solve_nfs(factor)) {\n            mpz_t cof;\n            mpz_init(cof);\n            mpz_divexact(cof, gN, factor);\n            if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n            gmp_printf(\"FACTOR: %Zd\\n\", factor);\n            fprintf(stderr, \"SNFS: done in %.2fs\\n\", walltime() - gStart);\n            mpz_clear(cof); mpz_clear(factor);\n            return 0;\n        }\n        mpz_clear(factor);\n    }\n\n    /* Fallback: ECM */\n    fprintf(stderr, \"SNFS: falling back to ECM\\n\");\n    {\n        ecm_params params;\n        ecm_init(params);\n        params->param = ECM_PARAM_SUYAMA;\n        mpz_t factor;\n        mpz_init(factor);\n        double b1s[] = {2000, 11000, 50000, 250000, 1e6, 3e6, 11e6, 44e6};\n        int curves[] = {25, 50, 100, 200, 400, 700, 1200, 2400};\n        for (int lev = 0; lev < 8; lev++) {\n            for (int c = 0; c < curves[lev]; c++) {\n                if (walltime() - gStart > 290.0) goto done2;\n                mpz_set_ui(factor, 0);\n                params->B1done = 1.0;\n                mpz_set_ui(params->sigma, 42 + lev * 10000 + c);\n                int ret = ecm_factor(factor, gN, b1s[lev], params);\n                if (ret > 0 && mpz_cmp_ui(factor, 1) > 0 && mpz_cmp(factor, gN) < 0) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    mpz_clear(cof);\n                    ecm_clear(params); mpz_clear(factor);\n                    return 0;\n                }\n            }\n        }\n        done2:\n        ecm_clear(params); mpz_clear(factor);\n    }\n\n    fprintf(stderr, \"SNFS: failed\\n\");\n    return 1;\n}\n","structuredPatch":[],"originalFile":null}}
