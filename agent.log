 ecm_params params; ecm_init(params);\n                params->param = ECM_PARAM_SUYAMA;\n                mpz_set_ui(params->sigma, 42 + (unsigned long)(b1/1000) * 1000 + c);\n                params->B1done = 1.0;\n                mpz_set_ui(factor, 0);\n                if (ecm_factor(factor, gN, (double)b1, params) > 0 &&\n                    mpz_cmp_ui(factor, 1) > 0 && mpz_cmp(factor, gN) < 0) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    ecm_clear(params); return 0;\n                }\n                ecm_clear(params);\n            }\n        }\n        fail:\n        mpz_clear(factor);\n    }\n\n    fprintf(stderr, \"SIQS: failed\\n\");\n    return 1;\n}\n","structuredPatch":[{"oldStart":549,"oldLines":17,"newStart":549,"newLines":31,"lines":["     /* For simplicity, I'll just try all relations and hope the matrix works */","     n = 0;","     for (int i = 0; i < gNRels; i++) {","-        /* Include fully smooth and combined partials */","+        /* Include fully smooth (cofactor=1) and combined partials","+         * (cofactor>1 from match_partials — identified by the ax_b being","+         * a product of two values mod kN, which means it's large) */","         if (mpz_cmp_ui(gRels[i].cofactor, 1) == 0) {","-            rel_map[n++] = i;","+            rel_map[n++] = i; /* full */","         }","-        /* Combined partials: have cofactor > 1 AND were created by match_partials","-         * (these are at the end of the array and their cofactor^2 is a perfect square) */","     }","+    /* Also include combined partials (those created by match_partials,","+     * which set cofactor = shared LP. They have cofactor^2 in the product,","+     * so they work for the congruence of squares. We identify them as","+     * having cofactor > 1 AND being at the end