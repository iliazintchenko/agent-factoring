{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EWx7FPFBbayGsDJwsWwaZD","type":"tool_result","content":"The file /tmp/agent-factoring-3/library/siqs_fast.c has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"f16ee78b-ee57-47d2-a561-91e9aefa955b","uuid":"ff00b0dc-8317-4832-a528-0ad84bb7db58","timestamp":"2026-03-24T03:13:24.732Z","tool_use_result":{"filePath":"/tmp/agent-factoring-3/library/siqs_fast.c","oldString":"        /* Try matching and solving periodically */\n        if (gNRels > gTarget / 2) {\n            int m = match_partials();\n            if (m > 0) fprintf(stderr, \"SIQS: matched %d partials\\n\", m);\n\n            /* Count usable relations */\n            usable_count = 0;\n            for (int i = 0; i < gNRels; i++)\n                if (gRels[i].usable) usable_count++;\n\n            if (usable_count >= gFBsize + 2) {\n                mpz_t factor;\n                mpz_init(factor);\n                if (solve(factor)) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    fprintf(stderr, \"SIQS: success in %.2fs\\n\", walltime() - gStart);\n                    return 0;\n                }\n                mpz_clear(factor);\n            }\n        }","newString":"        /* Count fulls periodically to check if we can try solving */\n        {\n            int fulls = 0;\n            for (int i = 0; i < gNRels; i++)\n                if (gRels[i].usable) fulls++;\n            usable_count = fulls;\n            /* Estimate matched: partials^2 / (2 * LP_range) */\n            int partials = gNRels - fulls;\n            double est_matches = (double)partials * partials / (2.0 * gLPbound / log(gLPbound + 1));\n            usable_count += (int)est_matches;\n        }","originalFile":"/*\n * siqs_fast.c — Fast Self-Initializing Quadratic Sieve\n *\n * Designed for 30-70 digit semiprimes. Key features:\n * - Self-initializing polynomials (SIQS): g(x) = (Ax+B)^2 - N\n *   where A is a product of factor base primes\n * - Small, fixed sieve interval (64K-256K) with many polynomials\n * - Aggressive double large prime (2LP) with hash-based matching\n * - Properly scaled parameters for the full 30-70 digit range\n * - GF(2) Gaussian elimination with null vector extraction\n *\n * Usage: ./siqs_fast <N>\n * Output: FACTOR: <p>\n */\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <math.h>\n#include <time.h>\n#include <gmp.h>\n#include <ecm.h>\n\n/* Configuration */\n#define MAX_FB     8192\n#define MAX_RELS   (MAX_FB * 6)\n#define SIEVE_HALF 65536       /* half sieve interval = 64K */\n\nstatic double gStart;\nstatic double walltime(void) {\n    struct timespec ts;\n    clock_gettime(CLOCK_MONOTONIC, &ts);\n    return ts.tv_sec + ts.tv_nsec * 1e-9;\n}\n\n/* Factor base */\ntypedef struct {\n    unsigned long p;\n    unsigned long sqrt_n;  /* sqrt(N) mod p */\n    double logp;           /* log2(p) */\n} fb_prime_t;\n\nstatic mpz_t gN, gkN;     /* N and kN (multiplier * N) */\nstatic int gMult = 1;      /* Knuth multiplier */\nstatic fb_prime_t gFB[MAX_FB];\nstatic int gFBsize = 0;\nstatic unsigned long gLPbound;\n\n/* Relations */\ntypedef struct {\n    mpz_t ax_b;        /* Ax + B value (the \"x\" for congruence of squares) */\n    mpz_t cofactor;     /* large prime cofactor (1 if fully smooth) */\n    unsigned long *exps; /* full exponent vector */\n    unsigned char *exp2; /* mod-2 exponent bitvector */\n    int usable;         /* 1 if fully smooth or combined partial */\n} rel_t;\n\nstatic rel_t gRels[MAX_RELS];\nstatic int gNRels = 0;\nstatic int gTarget = 0;\n\n/* Sieve array */\nstatic unsigned char gSieve[2 * SIEVE_HALF];\n\n/* ---- Utility functions ---- */\n\nstatic int is_prime(unsigned long n) {\n    if (n < 2) return 0; if (n < 4) return 1;\n    if (n % 2 == 0 || n % 3 == 0) return 0;\n    for (unsigned long d = 5; d * d <= n; d += 6)\n        if (n % d == 0 || n % (d+2) == 0) return 0;\n    return 1;\n}\n\nstatic unsigned long modpow(unsigned long base, unsigned long exp, unsigned long mod) {\n    unsigned long r = 1;\n    base %= mod;\n    while (exp > 0) {\n        if (exp & 1) r = (__uint128_t)r * base % mod;\n        base = (__uint128_t)base * base % mod;\n        exp >>= 1;\n    }\n    return r;\n}\n\nstatic unsigned long modsqrt(unsigned long a, unsigned long p) {\n    if (a == 0 || p == 2) return a % p;\n    if (modpow(a, (p-1)/2, p) != 1) return 0;\n    if (p % 4 == 3) return modpow(a, (p+1)/4, p);\n\n    unsigned long Q = p-1, S = 0;\n    while (!(Q&1)) { Q >>= 1; S++; }\n    unsigned long z = 2;\n    while (modpow(z, (p-1)/2, p) != p-1) z++;\n    unsigned long M = S;\n    unsigned long c = modpow(z, Q, p);\n    unsigned long t = modpow(a, Q, p);\n    unsigned long R = modpow(a, (Q+1)/2, p);\n    while (t != 1) {\n        unsigned long i = 0, tt = t;\n        while (tt != 1) { tt = (__uint128_t)tt*tt%p; i++; }\n        unsigned long b = c;\n        for (unsigned long j = 0; j < M-i-1; j++) b = (__uint128_t)b*b%p;\n        M = i; c = (__uint128_t)b*b%p;\n        t = (__uint128_t)t*c%p; R = (__uint128_t)R*b%p;\n    }\n    return R;\n}\n\n/* Knuth-Schroeppel multiplier selection */\nstatic int choose_multiplier(void) {\n    static const int mults[] = {1, 3, 5, 7, 11, 13, 15, 17, 19, 21, 23, 29, 31, 37, 41, 43};\n    int nmults = sizeof(mults)/sizeof(mults[0]);\n    double best_score = -1e9;\n    int best_k = 1;\n\n    for (int mi = 0; mi < nmults; mi++) {\n        int k = mults[mi];\n        mpz_t kn;\n        mpz_init(kn);\n        mpz_mul_ui(kn, gN, k);\n\n        double score = -0.5 * log(k);\n        for (unsigned long p = 2; p < 200; p++) {\n            if (!is_prime(p)) continue;\n            unsigned long kn_mod_p = mpz_fdiv_ui(kn, p);\n            if (kn_mod_p == 0) { score += log(p); continue; }\n            unsigned long r = modsqrt(kn_mod_p, p);\n            if (r > 0) score += 2.0 * log(p) / (p - 1);\n        }\n        if (score > best_score) { best_score = score; best_k = k; }\n        mpz_clear(kn);\n    }\n    return best_k;\n}\n\n/* Build factor base */\nstatic void build_fb(int target_size) {\n    gFBsize = 0;\n    for (unsigned long p = 2; gFBsize < target_size && p < 10000000; p++) {\n        if (!is_prime(p)) continue;\n        unsigned long kn_mod = mpz_fdiv_ui(gkN, p);\n        unsigned long r = (p == 2) ? (kn_mod & 1) : modsqrt(kn_mod, p);\n        if (r == 0 && kn_mod != 0) continue;\n        gFB[gFBsize].p = p;\n        gFB[gFBsize].sqrt_n = r;\n        gFB[gFBsize].logp = log2(p);\n        gFBsize++;\n    }\n    gTarget = gFBsize + 64;\n    gLPbound = (unsigned long)gFB[gFBsize-1].p * (unsigned long)gFB[gFBsize-1].p;\n    if (gLPbound > 1UL << 62) gLPbound = 1UL << 62;\n}\n\n/* Initialize a relation */\nstatic void rel_init(rel_t *r) {\n    mpz_init(r->ax_b);\n    mpz_init(r->cofactor);\n    r->exps = calloc(gFBsize + 1, sizeof(unsigned long));\n    r->exp2 = calloc((gFBsize + 8) / 8, 1);\n    r->usable = 0;\n}\n\nstatic void exp2_flip(unsigned char *e, int b) { e[b/8] ^= (1 << (b%8)); }\nstatic int exp2_get(unsigned char *e, int b) { return (e[b/8] >> (b%8)) & 1; }\n\n/* Trial divide val by factor base */\nstatic int trial_divide(mpz_t val, rel_t *rel) {\n    mpz_t tmp;\n    mpz_init(tmp);\n    mpz_abs(tmp, val);\n\n    int exp_bytes = (gFBsize + 8) / 8;\n    memset(rel->exps, 0, (gFBsize + 1) * sizeof(unsigned long));\n    memset(rel->exp2, 0, exp_bytes);\n\n    /* Sign */\n    if (mpz_sgn(val) < 0) {\n        rel->exps[0] = 1;\n        exp2_flip(rel->exp2, 0);\n    }\n\n    for (int i = 0; i < gFBsize; i++) {\n        unsigned long p = gFB[i].p;\n        unsigned long cnt = 0;\n        while (mpz_divisible_ui_p(tmp, p)) {\n            mpz_divexact_ui(tmp, tmp, p);\n            cnt++;\n        }\n        rel->exps[i + 1] = cnt;\n        if (cnt & 1) exp2_flip(rel->exp2, i + 1);\n    }\n\n    int smooth = (mpz_cmp_ui(tmp, 1) == 0);\n    mpz_set(rel->cofactor, tmp);\n    mpz_clear(tmp);\n    return smooth;\n}\n\n/* SIQS: generate polynomial g(x) = (Ax+B)^2 - N where A = product of primes */\ntypedef struct {\n    mpz_t A, B, C;           /* g(x) = Ax^2 + 2Bx + C, actually (Ax+B)^2 - N */\n    unsigned long *soln1;    /* sieve solutions for each FB prime */\n    unsigned long *soln2;\n    int *ainv;               /* A^{-1} mod p for each FB prime */\n    int n_a_factors;         /* number of primes in A */\n    int *a_indices;          /* which FB primes make up A */\n} poly_t;\n\nstatic void poly_init(poly_t *p) {\n    mpz_init(p->A); mpz_init(p->B); mpz_init(p->C);\n    p->soln1 = calloc(gFBsize, sizeof(unsigned long));\n    p->soln2 = calloc(gFBsize, sizeof(unsigned long));\n    p->ainv = calloc(gFBsize, sizeof(int));\n    p->a_indices = calloc(20, sizeof(int));\n}\n\n/* Generate A as product of s primes from the factor base.\n * Ideal A ≈ sqrt(2N) / M for sieve interval [-M, M]. */\nstatic int generate_A(poly_t *poly, int *used_count) {\n    /* Target A value */\n    mpz_t target_A, sqrt2N;\n    mpz_init(target_A); mpz_init(sqrt2N);\n    mpz_mul_ui(sqrt2N, gkN, 2);\n    mpz_sqrt(sqrt2N, sqrt2N);\n    mpz_tdiv_q_ui(target_A, sqrt2N, SIEVE_HALF);\n\n    /* Find FB primes whose product is close to target_A */\n    /* Use greedy: pick primes from middle of FB that multiply to target_A */\n    double log_target = log(mpz_get_d(target_A));\n    double log_accum = 0;\n\n    int start = gFBsize / 3;\n    int end = 2 * gFBsize / 3;\n    if (end - start < 5) { start = 2; end = gFBsize - 1; }\n\n    /* Deterministic selection based on used_count */\n    int seed = *used_count;\n    mpz_set_ui(poly->A, 1);\n    poly->n_a_factors = 0;\n\n    /* Pick primes greedily */\n    for (int iter = 0; iter < 20 && log_accum < log_target; iter++) {\n        int idx = start + ((seed + iter * 7) % (end - start));\n        if (idx < 2) idx = 2;\n        if (idx >= gFBsize) idx = gFBsize - 1;\n\n        /* Check this prime isn't already used */\n        int dup = 0;\n        for (int j = 0; j < poly->n_a_factors; j++)\n            if (poly->a_indices[j] == idx) { dup = 1; break; }\n        if (dup) continue;\n\n        poly->a_indices[poly->n_a_factors++] = idx;\n        mpz_mul_ui(poly->A, poly->A, gFB[idx].p);\n        log_accum += log(gFB[idx].p);\n    }\n\n    (*used_count)++;\n    mpz_clear(target_A); mpz_clear(sqrt2N);\n    return poly->n_a_factors >= 2;\n}\n\n/* Compute B such that B^2 ≡ N (mod A) using Hensel lifting */\nstatic int compute_B(poly_t *poly) {\n    /* B = CRT of sqrt(N) mod each prime factor of A */\n    mpz_t B_accum, term, A_part, inv;\n    mpz_init(B_accum); mpz_init(term); mpz_init(A_part); mpz_init(inv);\n    mpz_set_ui(B_accum, 0);\n\n    for (int i = 0; i < poly->n_a_factors; i++) {\n        int idx = poly->a_indices[i];\n        unsigned long p = gFB[idx].p;\n        unsigned long r = gFB[idx].sqrt_n;\n\n        /* A_part = A / p */\n        mpz_divexact_ui(A_part, poly->A, p);\n\n        /* inv = A_part^{-1} mod p */\n        mpz_set_ui(inv, modpow(mpz_fdiv_ui(A_part, p), p - 2, p));\n\n        /* term = r * inv * A_part */\n        mpz_mul_ui(term, inv, r);\n        mpz_mul(term, term, A_part);\n\n        mpz_add(B_accum, B_accum, term);\n    }\n\n    /* B = B_accum mod A */\n    mpz_mod(poly->B, B_accum, poly->A);\n\n    /* Ensure B^2 ≡ N (mod A) */\n    mpz_t check;\n    mpz_init(check);\n    mpz_mul(check, poly->B, poly->B);\n    mpz_mod(check, check, poly->A);\n    mpz_t nmod;\n    mpz_init(nmod);\n    mpz_mod(nmod, gkN, poly->A);\n    if (mpz_cmp(check, nmod) != 0) {\n        /* Try B = A - B */\n        mpz_sub(poly->B, poly->A, poly->B);\n    }\n    mpz_clear(check); mpz_clear(nmod);\n\n    /* C = (B^2 - N) / A */\n    mpz_mul(poly->C, poly->B, poly->B);\n    mpz_sub(poly->C, poly->C, gkN);\n    mpz_divexact(poly->C, poly->C, poly->A);\n\n    mpz_clear(B_accum); mpz_clear(term); mpz_clear(A_part); mpz_clear(inv);\n    return 1;\n}\n\n/* Compute sieve solutions for each FB prime */\nstatic void compute_solutions(poly_t *poly) {\n    for (int i = 0; i < gFBsize; i++) {\n        unsigned long p = gFB[i].p;\n\n        /* Check if p divides A */\n        int divides_A = 0;\n        for (int j = 0; j < poly->n_a_factors; j++)\n            if (gFB[poly->a_indices[j]].p == p) { divides_A = 1; break; }\n\n        if (divides_A || p == 2) {\n            poly->soln1[i] = poly->soln2[i] = (unsigned long)-1; /* skip */\n            continue;\n        }\n\n        /* Solve (Ax + B)^2 ≡ N (mod p), i.e., Ax + B ≡ ±√N (mod p)\n         * x ≡ A^{-1} * (±√N - B) (mod p) */\n        unsigned long A_mod = mpz_fdiv_ui(poly->A, p);\n        unsigned long B_mod = mpz_fdiv_ui(poly->B, p);\n        unsigned long A_inv = modpow(A_mod, p - 2, p);\n        unsigned long r = gFB[i].sqrt_n;\n\n        /* Solution 1: x ≡ A^{-1} * (r - B) mod p */\n        unsigned long s1 = (__uint128_t)A_inv * ((r + p - B_mod) % p) % p;\n        /* Solution 2: x ≡ A^{-1} * (-r - B) mod p */\n        unsigned long s2 = (__uint128_t)A_inv * ((p - r + p - B_mod) % p) % p;\n\n        /* Shift to sieve range [0, 2*SIEVE_HALF) */\n        s1 = (s1 + SIEVE_HALF) % p;\n        s2 = (s2 + SIEVE_HALF) % p;\n\n        poly->soln1[i] = s1;\n        poly->soln2[i] = s2;\n    }\n}\n\n/* Sieve one polynomial */\nstatic void sieve_poly(poly_t *poly) {\n    int slen = 2 * SIEVE_HALF;\n    memset(gSieve, 0, slen);\n\n    /* Sieve: add log(p) for each hit */\n    for (int i = 1; i < gFBsize; i++) { /* skip p=2 */\n        unsigned long p = gFB[i].p;\n        int lp = (int)(gFB[i].logp + 0.5);\n        if (lp < 1) lp = 1;\n        if (lp > 255) lp = 255;\n\n        if (poly->soln1[i] == (unsigned long)-1) continue;\n\n        for (unsigned long j = poly->soln1[i]; j < (unsigned long)slen; j += p)\n            gSieve[j] += lp;\n        if (poly->soln1[i] != poly->soln2[i]) {\n            for (unsigned long j = poly->soln2[i]; j < (unsigned long)slen; j += p)\n                gSieve[j] += lp;\n        }\n    }\n\n    /* Scan for smooth candidates */\n    /* Threshold: log2(value) - log2(LP_bound) */\n    /* Value at x: |g(x)| = |A*x^2 + 2*B*x + C| where x in [-SIEVE_HALF, SIEVE_HALF) */\n    /* Max value ≈ A * SIEVE_HALF^2 ≈ sqrt(2N)/M * M^2 = M * sqrt(2N) */\n    double log2_max = log2((double)SIEVE_HALF) + 0.5 * mpz_sizeinbase(gkN, 2);\n    double log2_lp = log2((double)gLPbound);\n    int threshold = (int)(log2_max - log2_lp - 5); /* 5 bits slack */\n    if (threshold < 10) threshold = 10;\n\n    mpz_t val, ax_b;\n    mpz_init(val); mpz_init(ax_b);\n\n    for (int j = 0; j < slen && gNRels < MAX_RELS; j++) {\n        if (gSieve[j] < threshold) continue;\n\n        int x = j - SIEVE_HALF;\n\n        /* Compute val = A*x^2 + 2*B*x + C = ((Ax+B)^2 - N) / A... no.\n         * Actually g(x) = (Ax+B)^2 - N.\n         * For the sieve, val = A*x^2 + 2*B*x + C where C = (B^2 - N)/A.\n         * So val = A * (x^2) + 2*B*x + C.\n         * And (Ax+B)^2 - N = A * val ... wait, let me recheck.\n         *\n         * g(x) = (Ax+B)^2 - N = A^2*x^2 + 2ABx + B^2 - N\n         *       = A * (Ax^2 + 2Bx + (B^2-N)/A) = A * (Ax^2 + 2Bx + C)\n         *\n         * We sieve over h(x) = Ax^2 + 2Bx + C = g(x)/A.\n         * If h(x) is smooth over the factor base, then g(x) = A * h(x)\n         * is smooth (since A is also a product of FB primes).\n         *\n         * The relation is: (Ax+B)^2 ≡ g(x) ≡ A * h(x) (mod N).\n         */\n\n        /* Compute h(x) = Ax^2 + 2Bx + C */\n        mpz_set_si(val, x);\n        mpz_mul(val, val, poly->A);      /* Ax */\n        mpz_addmul_ui(val, poly->B, 2);  /* Ax + 2B */\n        mpz_mul_si(val, val, x);         /* Ax^2 + 2Bx */\n        mpz_add(val, val, poly->C);      /* Ax^2 + 2Bx + C = h(x) */\n\n        /* ax_b = Ax + B (the x-value for the congruence) */\n        mpz_set_si(ax_b, x);\n        mpz_mul(ax_b, ax_b, poly->A);\n        mpz_add(ax_b, ax_b, poly->B);\n\n        /* Trial divide h(x) */\n        rel_t rel;\n        rel_init(&rel);\n        mpz_set(rel.ax_b, ax_b);\n\n        int smooth = trial_divide(val, &rel);\n\n        if (smooth) {\n            /* Full relation: include A's prime factors */\n            for (int k = 0; k < poly->n_a_factors; k++) {\n                int idx = poly->a_indices[k];\n                rel.exps[idx + 1] += 1; /* A contributes 1 to each prime's exponent */\n                if (1 & 1) exp2_flip(rel.exp2, idx + 1);\n            }\n            rel.usable = 1;\n            gRels[gNRels++] = rel;\n        } else if (mpz_sizeinbase(rel.cofactor, 2) <= 52 &&\n                   mpz_probab_prime_p(rel.cofactor, 2)) {\n            /* 1 large prime */\n            for (int k = 0; k < poly->n_a_factors; k++) {\n                int idx = poly->a_indices[k];\n                rel.exps[idx + 1] += 1;\n                exp2_flip(rel.exp2, idx + 1);\n            }\n            rel.usable = 0; /* not usable until matched */\n            gRels[gNRels++] = rel;\n        } else {\n            mpz_clear(rel.ax_b); mpz_clear(rel.cofactor);\n            free(rel.exps); free(rel.exp2);\n        }\n    }\n\n    mpz_clear(val); mpz_clear(ax_b);\n}\n\n/* Match partial relations (1LP) */\nstatic int match_partials(void) {\n    /* Sort by cofactor, find pairs */\n    int matches = 0;\n    int htsize = gNRels * 3 + 1;\n    int *ht = malloc(htsize * sizeof(int));\n    memset(ht, -1, htsize * sizeof(int));\n    int *used = calloc(gNRels, sizeof(int));\n\n    for (int i = 0; i < gNRels; i++) {\n        if (mpz_cmp_ui(gRels[i].cofactor, 1) == 0) continue; /* full */\n        if (used[i]) continue;\n\n        unsigned long h = mpz_fdiv_ui(gRels[i].cofactor, htsize);\n        for (int probe = 0; probe < htsize; probe++) {\n            int slot = (h + probe) % htsize;\n            if (ht[slot] == -1) { ht[slot] = i; break; }\n            int other = ht[slot];\n            if (used[other]) { ht[slot] = i; break; }\n            if (mpz_cmp(gRels[i].cofactor, gRels[other].cofactor) == 0) {\n                /* Match! Combine */\n                used[i] = 1; used[other] = 1;\n                if (gNRels < MAX_RELS) {\n                    rel_t *combined = &gRels[gNRels];\n                    rel_init(combined);\n                    mpz_mul(combined->ax_b, gRels[i].ax_b, gRels[other].ax_b);\n                    mpz_mod(combined->ax_b, combined->ax_b, gkN);\n                    mpz_set(combined->cofactor, gRels[i].cofactor);\n                    int exp_bytes = (gFBsize + 8) / 8;\n                    for (int b = 0; b < exp_bytes; b++)\n                        combined->exp2[b] = gRels[i].exp2[b] ^ gRels[other].exp2[b];\n                    for (int k = 0; k <= gFBsize; k++)\n                        combined->exps[k] = gRels[i].exps[k] + gRels[other].exps[k];\n                    combined->usable = 1;\n                    gNRels++;\n                    matches++;\n                }\n                break;\n            }\n        }\n    }\n\n    free(ht); free(used);\n    return matches;\n}\n\n/* Count full + matched relations */\nstatic int count_usable(void) {\n    int count = 0;\n    for (int i = 0; i < gNRels; i++) {\n        if (mpz_cmp_ui(gRels[i].cofactor, 1) == 0 ||\n            mpz_sizeinbase(gRels[i].cofactor, 2) > 1) {\n            /* Skip unmatched partials in this simple count */\n            /* Actually, count everything that either has cofactor=1 or\n             * is a combined relation (cofactor > 1 but matched) */\n        }\n        count++;\n    }\n    return count; /* All relations including unmatched partials */\n}\n\n/* GF(2) solve and extract factor */\nstatic int solve(mpz_t result) {\n    /* Only use full relations and matched partials */\n    int n = 0;\n    int *rel_map = malloc(gNRels * sizeof(int));\n    for (int i = 0; i < gNRels; i++) {\n        if (mpz_cmp_ui(gRels[i].cofactor, 1) == 0) {\n            rel_map[n++] = i;\n        } else {\n            /* Check if this is a combined partial (cofactor > 1 but even exponent implied) */\n            /* For combined partials from match_partials, cofactor is stored */\n            /* Actually, let me just include ALL relations in the matrix.\n             * The unmatched ones will have an extra column for their LP. */\n            /* For simplicity: only include fully smooth + combined relations */\n            /* A combined relation has cofactor = shared LP, but the LP exponent\n             * is 2 (one from each partial), which is even. So cofactor drops out\n             * of the GF(2) matrix. We can include it. */\n            /* How to identify combined? Combined have 2x cofactor */\n            /* Actually this is getting complicated. Let me just include relations\n             * where cofactor is 1 OR where the relation is \"combined\" (has large cofactor\n             * but the cofactor came from matching). */\n            /* For now: skip unmatched partials. Include everything else. */\n            rel_map[n++] = i;\n        }\n    }\n\n    /* Actually, simplify: only use relations with cofactor=1 (fully smooth and combined) */\n    n = 0;\n    /* After match_partials, combined relations have cofactor = large prime.\n     * We need to mark them differently. Let me just count all rels where\n     * either cofactor=1 or cofactor appeared as a combined LP. */\n    /* Simplest: include ALL, treat large prime as an additional column if unmatched */\n    /* For now, just include rels where cofactor = 1 (true fulls) */\n    /* and combined partials (which have cofactor > 1 but are matched) */\n\n    /* Let's be smarter: after match_partials, the combined relations are\n     * appended at the end with cofactor = the shared LP. For these,\n     * the LP appears with exponent 2, so it drops from GF(2).\n     * But the original (unmatched) partials still have cofactor > 1.\n     * We should ONLY use: fulls (cofactor=1) + combined (at end of array). */\n\n    /* For simplicity, I'll just try all relations and hope the matrix works */\n    n = 0;\n    for (int i = 0; i < gNRels; i++) {\n        if (gRels[i].usable) {\n            rel_map[n++] = i;\n        }\n    }\n\n    int m = gFBsize + 1; /* columns */\n    if (n < m + 1) { free(rel_map); return 0; }\n\n    fprintf(stderr, \"SIQS: solving %d x %d matrix\\n\", n, m);\n\n    int words = (m + n + 63) / 64;\n    unsigned long *mat = calloc((size_t)n * words, sizeof(unsigned long));\n\n    #define MG(r,c) ((mat[(size_t)(r)*words+(c)/64]>>((c)%64))&1)\n    #define MS(r,c) (mat[(size_t)(r)*words+(c)/64]|=(1UL<<((c)%64)))\n    #define MX(d,s) do{for(int _w=0;_w<words;_w++) mat[(size_t)(d)*words+_w]^=mat[(size_t)(s)*words+_w];}while(0)\n\n    for (int i = 0; i < n; i++) {\n        int ri = rel_map[i];\n        for (int j = 0; j <= gFBsize; j++)\n            if (exp2_get(gRels[ri].exp2, j)) MS(i, j);\n        MS(i, m + i);\n    }\n\n    int rank = 0;\n    for (int j = 0; j < m && rank < n; j++) {\n        int piv = -1;\n        for (int i = rank; i < n; i++) if (MG(i,j)) { piv = i; break; }\n        if (piv < 0) continue;\n        if (piv != rank) {\n            for (int w = 0; w < words; w++) {\n                unsigned long t = mat[(size_t)rank*words+w];\n                mat[(size_t)rank*words+w] = mat[(size_t)piv*words+w];\n                mat[(size_t)piv*words+w] = t;\n            }\n        }\n        for (int i = 0; i < n; i++)\n            if (i != rank && MG(i,j)) MX(i, rank);\n        rank++;\n    }\n\n    fprintf(stderr, \"SIQS: rank=%d, %d null vectors\\n\", rank, n - rank);\n\n    mpz_t X, Y, g, tmp;\n    mpz_init(X); mpz_init(Y); mpz_init(g); mpz_init(tmp);\n    int found = 0;\n\n    for (int row = rank; row < n && !found; row++) {\n        mpz_set_ui(X, 1);\n        unsigned long *tot = calloc(gFBsize + 1, sizeof(unsigned long));\n        int count = 0;\n\n        for (int i = 0; i < n; i++) {\n            if (!MG(row, m + i)) continue;\n            count++;\n            int ri = rel_map[i];\n            mpz_mul(X, X, gRels[ri].ax_b);\n            mpz_mod(X, X, gkN);\n            for (int k = 0; k <= gFBsize; k++)\n                tot[k] += gRels[ri].exps[k];\n        }\n\n        if (count == 0) { free(tot); continue; }\n\n        /* Compute Y */\n        mpz_set_ui(Y, 1);\n        for (int k = 1; k <= gFBsize; k++) {\n            if (tot[k] == 0) continue;\n            unsigned long half = tot[k] / 2;\n            if (half == 0) continue;\n            mpz_set_ui(tmp, gFB[k-1].p);\n            mpz_powm_ui(tmp, tmp, half, gkN);\n            mpz_mul(Y, Y, tmp);\n            mpz_mod(Y, Y, gkN);\n        }\n\n        /* Include cofactors from combined partials */\n        for (int i = 0; i < n; i++) {\n            if (!MG(row, m + i)) continue;\n            int ri = rel_map[i];\n            if (mpz_cmp_ui(gRels[ri].cofactor, 1) > 0) {\n                mpz_mul(Y, Y, gRels[ri].cofactor);\n                mpz_mod(Y, Y, gkN);\n            }\n        }\n\n        /* Try gcd */\n        mpz_sub(tmp, X, Y);\n        mpz_gcd(g, tmp, gN); /* Use gN, not gkN */\n        if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {\n            mpz_set(result, g);\n            found = 1;\n        }\n        if (!found) {\n            mpz_add(tmp, X, Y);\n            mpz_gcd(g, tmp, gN);\n            if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {\n                mpz_set(result, g);\n                found = 1;\n            }\n        }\n        free(tot);\n    }\n\n    mpz_clear(X); mpz_clear(Y); mpz_clear(g); mpz_clear(tmp);\n    free(mat); free(rel_map);\n    return found;\n\n    #undef MG\n    #undef MS\n    #undef MX\n}\n\n/* Choose parameters */\nstatic int choose_fb_size(int digits) {\n    double lnN = digits * 2.302585;\n    double lnlnN = log(lnN);\n    double B = exp(0.5 * sqrt(lnN * lnlnN));\n    int sz = (int)(B / log(B) * 0.6);\n    if (sz < 40) sz = 40;\n    if (sz > MAX_FB) sz = MAX_FB;\n    return sz;\n}\n\nint main(int argc, char *argv[]) {\n    if (argc < 2) { fprintf(stderr, \"Usage: %s <N>\\n\", argv[0]); return 1; }\n    gStart = walltime();\n\n    mpz_init(gN); mpz_init(gkN);\n    mpz_set_str(gN, argv[1], 10);\n    int digits = strlen(argv[1]);\n\n    /* Trial division */\n    for (unsigned long p = 2; p < 1000000; p++) {\n        if (mpz_divisible_ui_p(gN, p)) {\n            printf(\"FACTOR: %lu\\n\", p);\n            return 0;\n        }\n    }\n\n    /* Multiplier */\n    gMult = choose_multiplier();\n    mpz_mul_ui(gkN, gN, gMult);\n\n    /* Build factor base */\n    int fb_target = choose_fb_size(digits);\n    build_fb(fb_target);\n    fprintf(stderr, \"SIQS: %d-digit, mult=%d, FB=%d, LP_bound=%lu\\n\",\n            digits, gMult, gFBsize, gLPbound);\n\n    /* Main SIQS loop */\n    poly_t poly;\n    poly_init(&poly);\n    int poly_count = 0;\n    int last_report = 0;\n\n    int usable_count = 0;\n    while (usable_count < gTarget) {\n        if (walltime() - gStart > 280.0) break;\n\n        if (!generate_A(&poly, &poly_count)) continue;\n        compute_B(&poly);\n        compute_solutions(&poly);\n        sieve_poly(&poly);\n\n        if (gNRels > last_report + 50) {\n            int fulls = 0, partials = 0;\n            for (int i = 0; i < gNRels; i++) {\n                if (mpz_cmp_ui(gRels[i].cofactor, 1) == 0) fulls++;\n                else partials++;\n            }\n            fprintf(stderr, \"SIQS: [%.1fs] %d rels (%d full, %d partial) from %d polys\\n\",\n                    walltime() - gStart, gNRels, fulls, partials, poly_count);\n            last_report = gNRels;\n        }\n\n        /* Try matching and solving periodically */\n        if (gNRels > gTarget / 2) {\n            int m = match_partials();\n            if (m > 0) fprintf(stderr, \"SIQS: matched %d partials\\n\", m);\n\n            /* Count usable relations */\n            usable_count = 0;\n            for (int i = 0; i < gNRels; i++)\n                if (gRels[i].usable) usable_count++;\n\n            if (usable_count >= gFBsize + 2) {\n                mpz_t factor;\n                mpz_init(factor);\n                if (solve(factor)) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    fprintf(stderr, \"SIQS: success in %.2fs\\n\", walltime() - gStart);\n                    return 0;\n                }\n                mpz_clear(factor);\n            }\n        }\n    }\n\n    fprintf(stderr, \"SIQS: sieve phase done, attempting solve...\\n\");\n    match_partials();\n    {\n        mpz_t factor;\n        mpz_init(factor);\n        if (solve(factor)) {\n            mpz_t cof; mpz_init(cof);\n            mpz_divexact(cof, gN, factor);\n            if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n            gmp_printf(\"FACTOR: %Zd\\n\", factor);\n            fprintf(stderr, \"SIQS: success in %.2fs\\n\", walltime() - gStart);\n            return 0;\n        }\n        mpz_clear(factor);\n    }\n\n    /* ECM fallback */\n    fprintf(stderr, \"SIQS: ECM fallback\\n\");\n    {\n        mpz_t factor; mpz_init(factor);\n        /* Quick ECM */\n        for (unsigned long b1 = 2000; b1 < 200000000; b1 *= 3) {\n            for (int c = 0; c < 100; c++) {\n                if (walltime() - gStart > 290.0) goto fail;\n                ecm_params params; ecm_init(params);\n                params->param = ECM_PARAM_SUYAMA;\n                mpz_set_ui(params->sigma, 42 + (unsigned long)(b1/1000) * 1000 + c);\n                params->B1done = 1.0;\n                mpz_set_ui(factor, 0);\n                if (ecm_factor(factor, gN, (double)b1, params) > 0 &&\n                    mpz_cmp_ui(factor, 1) > 0 && mpz_cmp(factor, gN) < 0) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    ecm_clear(params); return 0;\n                }\n                ecm_clear(params);\n            }\n        }\n        fail:\n        mpz_clear(factor);\n    }\n\n    fprintf(stderr, \"SIQS: failed\\n\");\n    return 1;\n}\n","structuredPatch":[{"oldStart":730,"oldLines":29,"newStart":730,"newLines":16,"lines":["             last_report = gNRels;","         }"," ","-        /* Try matching and solving periodically */","-        if (gNRels > gTarget / 2) {","-            int m = match_partials();","-            if (m > 0) fprintf(stderr, \"SIQS: matched %d partials\\n\", m);","-","-            /* Count usable relations */","-            usable_count = 0;","+        /* Count fulls periodically to check if we can try solving */","+        {","+            int fulls = 0;","             for (int i = 0; i < gNRels; i++)","-                if (gRels[i].usable) usable_count++;","-","-            if (usable_count >= gFBsize + 2) {","-                mpz_t factor;","-                mpz_init(factor);","-                if (solve(factor)) {","-                    mpz_t cof; mpz_init(cof);","-                    mpz_divexact(cof, gN, factor);","-                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);","-                    gmp_printf(\"FACTOR: %Zd\\n\", factor);","-                    fprintf(stderr, \"SIQS: success in %.2fs\\n\", walltime() - gStart);","-                    return 0;","-                }","-                mpz_clear(factor);","-            }","+                if (gRels[i].usable) fulls++;","+            usable_count = fulls;","+            /* Estimate matched: partials^2 / (2 * LP_range) */","+            int partials = gNRels - fulls;","+            double est_matches = (double)partials * partials / (2.0 * gLPbound / log(gLPbound + 1));","+            usable_count += (int)est_matches;","       