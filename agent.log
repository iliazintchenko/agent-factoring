 1) == 0) fulls++;\n                else partials++;\n            }\n            fprintf(stderr, \"SIQS: [%.1fs] %d rels (%d full, %d partial) from %d polys\\n\",\n                    walltime() - gStart, gNRels, fulls, partials, poly_count);\n            last_report = gNRels;\n        }\n\n        /* Try matching and solving periodically */\n        if (gNRels > gTarget) {\n            match_partials();\n\n            /* Count usable relations */\n            int fulls = 0;\n            for (int i = 0; i < gNRels; i++)\n                if (mpz_cmp_ui(gRels[i].cofactor, 1) == 0) fulls++;\n\n            if (fulls >= gFBsize + 2) {\n                mpz_t factor;\n                mpz_init(factor);\n                if (solve(factor)) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    fprintf(stderr, \"SIQS: success in %.2fs\\n\", walltime() - gStart);\n                    return 0;\n                }\n                mpz_clear(factor);\n            }\n        }\n    }\n\n    fprintf(stderr, \"SIQS: sieve phase done, attempting solve...\\n\");\n    match_partials();\n    {\n        mpz_t factor;\n        mpz_init(factor);\n        if (solve(factor)) {\n            mpz_t cof; mpz_init(cof);\n            mpz_divexact(cof, gN, factor);\n            if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n            gmp_printf(\"FACTOR: %Zd\\n\", factor);\n            fprintf(stderr, \"SIQS: success in %.2fs\\n\", walltime() - gStart);\n            return 0;\n        }\n        mpz_clear(factor);\n    }\n\n    /* ECM fallback */\n    fprintf(stderr, \"SIQS: ECM fallback\\n\");\n    {\n        mpz_t factor; mpz_init(factor);\n        /* Quick ECM */\n        for (unsigned long b1 = 2000; b1 < 200000000; b1 *= 3) {\n            for (int c = 0; c < 100; c++) {\n                if (walltime() - gStart > 290.0) goto fail;\n                ecm_params params; ecm_init(params);\n                params->param = ECM_PARAM_SUYAMA;\n                mpz_set_ui(params->sigma, 42 + (unsigned long)(b1/1000) * 1000 + c);\n                params->B1done = 1.0;\n                mpz_set_ui(factor, 0);\n                if (ecm_factor(factor, gN, (double)b1, params) > 0 &&\n                    mpz_cmp_ui(factor, 1) > 0 && mpz_cmp(factor, gN) < 0) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    ecm_clear(params); return 0;\n                }\n                ecm_clear(params);\n            }\n        }\n        fail:\n        mpz_clear(factor);\n    }\n\n    fprintf(stderr, \"SIQS: failed\\n\");\n    return 1;\n}\n","structuredPatch":[{"oldStart":428,"oldLines":6,"newStart":428,"newLines":7,"lines":["                 rel.exps[idx + 1] += 1; /* A contributes 1 to each prime's exponent */","                 if (1 & 1) exp2_flip(rel.exp2, idx + 1);","             }","+            rel.usable = 1;","             gRels[gNRels++] = rel;","         } else if (mpz_sizeinbase(rel.cofactor, 2) <= 52 &&","                    mpz_probab_prime_p(rel.cofactor, 2)) {"]},{"oldStart":437,"oldLines":6,"newStart":438,"newLines":7,"lines":["                 rel.exps[idx + 1] += 1;","                 exp2_flip(rel.exp2, idx + 1);","             }","+            rel.usable = 0; /* not usable until matched */","             gRels[gNRels++] = rel;","         } else {","             mpz_clear(rel.ax_b); mpz_clear(rel.cofactor);"]}],"userModified":false,"replaceAll":false}}
