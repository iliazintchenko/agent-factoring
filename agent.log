N) */","         mpz_sub(tmp, X, Y);","-        mpz_gcd(g, tmp, N);","-        if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, N) < 0) {","+        mpz_gcd(g, tmp, gN);","+        if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {","             mpz_set(result, g);","             found = 1;","         }","         if (!found) {","             mpz_add(tmp, X, Y);","-            mpz_gcd(g, tmp, N);","-            if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, N) < 0) {","+            mpz_gcd(g, tmp, gN);","+            if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, gN) < 0) {","                 mpz_set(result, g);","                 found = 1;","             }","         }"," ","-        free(total_exp);","+        free(tot);","     }"," ","     mpz_clear(X); mpz_clear(Y); mpz_clear(g); mpz_clear(tmp);","-    free(pivot_col);","-    free(mat.rows);","+    free(mat);","     return found;","+","+    #undef MGET","+    #undef MSET","+    #undef MFLIP","+    #undef MXOR_ROW"," }"," ","-/* ---------- Optimal parameter selection ---------- */","-static int optimal_fb_size(int digits) {","-    /* Practical QS factor base sizes, tuned for each digit range.","-     * Factor base bound B = exp(0.5 * sqrt(ln N * ln ln N))","-     * Factor base size = π(B) ≈ B / ln(B) */","+static int choose_fb_size(int digits) {","+    /* Practical: for d-digit N, FB size ≈ exp(0.5 * sqrt(d * ln(10) * ln(d * ln(10)))) / ln(B) */","     double lnN = digits * 2.302585;","     double lnlnN = log(lnN);","     double B = exp(0.5 * sqrt(lnN * lnlnN));","-    int sz = (int)(B / log(B));","-    /* Apply practical correction factor */","-    sz = (int)(sz * 0.7);","+    double lnB = log(B);","+    int sz = (int)(B / lnB);","     if (sz < 40) sz = 40;","-    if (sz > MAX_FB_SIZE) sz = MAX_FB_SIZE;","+    if (sz > MAX_FB) sz = MAX_FB;","     return sz;"," }"," ","-/* ---------- Main ---------- */"," int main(int argc, char *argv[]) {","     if (argc < 2) {","         fprintf(stderr, \"Usage: %s <N>\\n\", argv[0]);","         return 1;","     }"," ","-    start_time = now_sec();","-","-    mpz_init(N);","-    mpz_init(sqrtN);","-    mpz_set_str(N, argv[1], 10);","-","+    gStart = walltime();","+    mpz_init(gN);","+    mpz_init(gSqrtN);","+    mpz_set_str(gN, argv[1], 10);","     int digits = strlen(argv[1]);"," ","-    if (mpz_cmp_ui(N, 1) <= 0 || mpz_probab_prime_p(N, 25)) {","-        fprintf(stderr, \"N is trivial or prime\\n\");","+    if (mpz_probab_prime_p(gN, 25)) {","+        fprintf(stderr, \"N is prime\\n\");","         return 1;","     }"," ","-    /* Check for small factors first */","-    {","-        mpz_t f;","-        mpz_init(f);","-        for (unsigned long p = 2; p < 1000000; p++) {","-            if (mpz_divisible_ui_p(N, p)) {","-                mpz_set_ui(f, p);","-                mpz_t cof;","-                mpz_init(cof);","-                mpz_divexact(cof, N, f);","-                if (mpz_cmp(f, cof) > 0) mpz_set(f, cof);","-                gmp_printf(\"FACTOR: %Zd\\n\", f);","-                mpz_clear(f); mpz_clear(cof);","+    /* Trial division */","+    for (unsigned long p = 2; p < 1000000; p++) {","+        if (mpz_divisible_ui_p(gN, p)) {","+            mpz_t f, c;","+            mpz_init(f); mpz_init(c);","+            mpz_set_ui(f, p);","+            mpz_divexact(c, gN, f);","+            if (mpz_cmp(f, c) > 0) mpz_set(f, c);","+            gmp_printf(\"FACTOR: %Zd\\n\", f);","+            return 0;","+        }","+    }","+","+    /* Perfect power check */","+    if (mpz_perfect_power_p(gN)) {","+        mpz_t root;","+        mpz_init(root);","+        for (int e = 2; e < 64; e++) {","+            if (mpz_root(root, gN, e)) {","+                gmp_printf(\"FACTOR: %Zd\\n\", root);","+                mpz_clear(root);","                 return 0;","             }","         }","-        mpz_clear(f);","+        mpz_clear(root);","     }"," ","-    mpz_sqrt(sqrtN, N);","-    /* Adjust: ensure sqrtN^2 >= N */","-    {","-        mpz_t tmp;","-        mpz_