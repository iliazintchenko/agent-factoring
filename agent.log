   mpz_t factor;\n        mpz_init(factor);\n\n        fprintf(stderr, \"CCD: starting linear algebra (%d x %d)\\n\", n_fulls, fb_size + 1);\n\n        if (attempt_factor(factor)) {\n            /* Return smaller factor */\n            mpz_t cofactor;\n            mpz_init(cofactor);\n            mpz_divexact(cofactor, N, factor);\n            if (mpz_cmp(factor, cofactor) > 0)\n                mpz_set(factor, cofactor);\n            gmp_printf(\"FACTOR: %Zd\\n\", factor);\n            mpz_clear(cofactor);\n            mpz_clear(factor);\n            fprintf(stderr, \"CCD: success in %.2fs\\n\", now_sec() - start_time);\n        } else {\n            fprintf(stderr, \"CCD: linear algebra did not find factor\\n\");\n            /* Fallback to ECM */\n            goto ecm_fallback;\n        }\n    } else {\n        fprintf(stderr, \"CCD: insufficient relations (%d < %d)\\n\", n_fulls, fb_size + 2);\n        goto ecm_fallback;\n    }\n\n    /* Cleanup */\n    free(sieve_array);\n    for (int i = 0; i < n_fulls; i++) {\n        mpz_clear(fulls[i].x); mpz_clear(fulls[i].cofactor);\n        free(fulls[i].exponents);\n    }\n    for (int i = 0; i < n_partials; i++) {\n        mpz_clear(partials[i].x); mpz_clear(partials[i].cofactor);\n        free(partials[i].exponents);\n    }\n    mpz_clear(N); mpz_clear(sqrtN);\n    return 0;\n\necm_fallback:\n    {\n        fprintf(stderr, \"CCD: falling back to ECM\\n\");\n        free(sieve_array);\n        ecm_params params;\n        ecm_init(params);\n        params->param = ECM_PARAM_SUYAMA;\n        mpz_t factor;\n        mpz_init(factor);\n\n        double ecm_schedule[] = {2000, 11000, 50000, 250000, 1000000,\n                                  3000000, 11000000, 44000000, 110000000};\n        int ecm_curves[] = {20, 50, 100, 200, 400, 700, 1200, 2400, 4800};\n\n        for (int lev = 0; lev < 9; lev++) {\n            for (int c = 0; c < ecm_curves[lev]; c++) {\n                if (now_sec() - start_time > 290.0) goto ecm_done;\