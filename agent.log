      mat.rows[(size_t)rank * mat.words_per_row + w] =\n                    mat.rows[(size_t)piv * mat.words_per_row + w];\n                mat.rows[(size_t)piv * mat.words_per_row + w] = tmp;\n            }\n        }\n\n        /* Eliminate */\n        for (int i = 0; i < n; i++) {\n            if (i != rank && gf2_get(&mat, i, j)) {\n                gf2_xor_rows(&mat, i, rank);\n            }\n        }\n        pivot_col[rank] = j;\n        rank++;\n    }\n\n    /* Rows rank..n-1 are in the null space */\n    mpz_t X, Y, g, tmp;\n    mpz_init(X); mpz_init(Y); mpz_init(g); mpz_init(tmp);\n\n    int found = 0;\n    for (int row = rank; row < n && !found; row++) {\n        /* Collect the relations in this dependency */\n        mpz_set_ui(X, 1);\n        unsigned long *total_exp = calloc(fb_size, sizeof(unsigned long));\n        int total_sign = 0;\n\n        for (int i = 0; i < n; i++) {\n            if (!gf2_get(&mat, row, m + i)) continue;\n\n            /* Multiply X by this relation's x value */\n            mpz_mul(X, X, fulls[i].x);\n            mpz_mod(X, X, N);\n\n            /* Accumulate exponents */\n            int sign = (fulls[i].exponents[0] >> 31) & 1;\n            total_sign ^= sign;\n            for (int j = 0; j < fb_size; j++)\n                total_exp[j] += (fulls[i].exponents[j] & ~(1UL << 31));\n        }\n\n        /* All exponents should be even now */\n        /* Compute Y = product of p_i^(exp_i/2) mod N */\n        mpz_set_ui(Y, 1);\n        for (int j = 0; j < fb_size; j++) {\n            if (total_exp[j] == 0) continue;\n            unsigned long half_exp = total_exp[j] / 2;\n            mpz_set_ui(tmp, fb[j].p);\n            mpz_powm_ui(tmp, tmp, half_exp, N);\n            mpz_mul(Y, Y, tmp);\n            mpz_mod(Y, Y, N);\n        }\n\n        /* Try gcd(X - Y, N) and gcd(X + Y, N) */\n        mpz_sub(tmp, X, Y);\n        mpz_gcd(g, tmp, N);\n        if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, N) < 0) {\n            mpz_set(result, g);\