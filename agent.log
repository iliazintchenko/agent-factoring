42 + (unsigned long)lev * 10000 + c);\n                int ret = ecm_factor(factor, gN, b1s[lev], params);\n                if (ret > 0 && mpz_cmp_ui(factor, 1) > 0 && mpz_cmp(factor, gN) < 0) {\n                    mpz_t cof; mpz_init(cof);\n                    mpz_divexact(cof, gN, factor);\n                    if (mpz_cmp(factor, cof) > 0) mpz_set(factor, cof);\n                    gmp_printf(\"FACTOR: %Zd\\n\", factor);\n                    mpz_clear(cof);\n                    ecm_clear(params);\n                    mpz_clear(factor);\n                    return 0;\n                }\n            }\n        }\n        done:\n        ecm_clear(params);\n        mpz_clear(factor);\n    }\n\n    fprintf(stderr, \"CCD: failed\\n\");\n    return 1;\n}\n","structuredPatch":[{"oldStart":356,"oldLines":7,"newStart":356,"newLines":8,"lines":["                     rel_init(full);","                     mpz_mul(full->x, gPartials[i].x, gPartials[other].x);","                     mpz_mod(full->x, full->x, gN);","-                    mpz_set_ui(full->cofactor, 1);","+                    /* Store the shared cofactor — needed for square root step */","+                    mpz_set(full->cofactor, gPartials[i].cofactor);"," ","                     /* XOR exponent bits (mod 2) — cofactor appears twice so cancels */","                     for (int b = 0; b < gExpBytes; b++)"]}],"userModified":false,"replaceAll":false}}
