{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Dgn8vr2kMzypfTmTGyUyoF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MErk37TzJugzXJr5D45jji","name":"Write","input":{"file_path":"/tmp/agent-factoring-3/library/nfs_sieve.c","content":"/*\n * nfs_sieve.c — Line-sieved Number Field Sieve factoring\n * Usage: ./nfs_sieve <N>\n * Output: FACTOR: <p>\n * Compile: gcc -O3 -o nfs_sieve nfs_sieve.c -lgmp -lecm -lm\n *\n * Implements:\n *  - Base-m polynomial selection\n *  - Line sieving (rational + algebraic sides)\n *  - GF(2) Gaussian elimination for dependencies\n *  - Algebraic square root via polynomial arithmetic in Z[alpha]/(f) mod N\n *  - Factor extraction via gcd(X - Y, N)\n *  - ECM fallback\n */\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <math.h>\n#include <time.h>\n#include <gmp.h>\n#include <ecm.h>\n\nstatic double wall(void) {\n    struct timespec t;\n    clock_gettime(CLOCK_MONOTONIC, &t);\n    return t.tv_sec + t.tv_nsec * 1e-9;\n}\n\nstatic int *sieve_primes(int B, int *cnt) {\n    char *s = (char *)calloc(B + 1, 1);\n    for (int i = 2; i <= B; i++) s[i] = 1;\n    for (int i = 2; (long long)i * i <= B; i++)\n        if (s[i]) for (int j = i * i; j <= B; j += i) s[j] = 0;\n    int n = 0;\n    for (int i = 2; i <= B; i++) if (s[i]) n++;\n    int *p = (int *)malloc(n * sizeof(int));\n    int k = 0;\n    for (int i = 2; i <= B; i++) if (s[i]) p[k++] = i;\n    *cnt = n; free(s); return p;\n}\n\n/* ── GF(2) matrix ───────────────────────────────────────────── */\n#define WB 64\ntypedef unsigned long W;\ntypedef struct { W *d; int nr, nc, wpr; } mat_t;\n\nstatic void mat_init(mat_t *M, int nr, int nc) {\n    M->nr = nr; M->nc = nc;\n    M->wpr = (nc + WB - 1) / WB;\n    M->d = (W *)calloc((size_t)nr * M->wpr, sizeof(W));\n}\nstatic inline W *mat_row(mat_t *M, int r) { return M->d + (size_t)r * M->wpr; }\nstatic inline void mat_set(mat_t *M, int r, int c) {\n    mat_row(M, r)[c/WB] |= 1UL << (c%WB);\n}\nstatic inline int mat_get(mat_t *M, int r, int c) {\n    return (mat_row(M, r)[c/WB] >> (c%WB)) & 1;\n}\nstatic inline void mat_xor(mat_t *M, int dst, int src) {\n    W *d = mat_row(M, dst), *s = mat_row(M, src);\n    for (int i = 0; i < M->wpr; i++) d[i] ^= s[i];\n}\nstatic void mat_free(mat_t *M) { free(M->d); }\n\n/* ── Polynomial in Z/NZ[x] mod f(x), degree < deg ──────────── */\n/* Represented as array of mpz_t coefficients, index = power of alpha */\n\n/* Multiply two polynomials mod f mod N.\n   a, b are arrays of length deg (coeffs of alpha^0 .. alpha^(deg-1))\n   f is the defining polynomial of degree deg: f[0..deg] (leading = f[deg])\n   Result goes in res (length deg).\n*/\nstatic void poly_mul_mod(mpz_t *res, const mpz_t *a, const mpz_t *b,\n                         const mpz_t *f, int deg, const mpz_t N) {\n    /* Product has degree up to 2*(deg-1) */\n    int plen = 2 * deg - 1;\n    mpz_t *prod = (mpz_t *)malloc(plen * sizeof(mpz_t));\n    for (int i = 0; i < plen; i++) mpz_init(prod[i]);\n\n    mpz_t tmp;\n    mpz_init(tmp);\n\n    /* Convolution */\n    for (int i = 0; i < deg; i++) {\n        for (int j = 0; j < deg; j++) {\n            mpz_mul(tmp, a[i], b[j]);\n            mpz_add(prod[i+j], prod[i+j], tmp);\n            mpz_mod(prod[i+j], prod[i+j], N);\n        }\n    }\n\n    /* Reduce mod f: for each degree k from 2*deg-2 down to deg,\n       replace alpha^k with -(f[0]*alpha^(k-deg) + ... + f[deg-1]*alpha^(k-1)) / f[deg]\n       Since f is monic in our case (or we handle leading coeff),\n       we need to handle f[deg] != 1. */\n\n    /* For base-m, f[deg] = c_d (leading coefficient).\n       alpha^deg = -(c_{d-1}/c_d)*alpha^{d-1} - ... - (c_0/c_d)\n       But c_d might not be invertible mod N (that would give us a factor!).\n       Try to compute inverse; if it fails, gcd gives a factor. */\n\n    mpz_t lc_inv;\n    mpz_init(lc_inv);\n    int inv_ok = mpz_invert(lc_inv, f[deg], N);\n    if (!inv_ok) {\n        /* gcd(f[deg], N) is a factor -- but we handle this elsewhere */\n        /* Use a fallback: set lc_inv = 0 and hope for the best */\n        mpz_set_ui(lc_inv, 0);\n    }\n\n    for (int k = plen - 1; k >= deg; k--) {\n        if (mpz_sgn(prod[k]) == 0) continue;\n        /* alpha^k = alpha^(k-deg) * alpha^deg\n           alpha^deg = -sum_{i=0}^{deg-1} (f[i]/f[deg]) * alpha^i\n           So: subtract prod[k] * f[i] / f[deg] from prod[k-deg+i] for each i */\n        mpz_mul(tmp, prod[k], lc_inv);\n        mpz_mod(tmp, tmp, N);\n        for (int i = 0; i < deg; i++) {\n            mpz_t sub;\n            mpz_init(sub);\n            mpz_mul(sub, tmp, f[i]);\n            mpz_sub(prod[k - deg + i], prod[k - deg + i], sub);\n            mpz_mod(prod[k - deg + i], prod[k - deg + i], N);\n            mpz_clear(sub);\n        }\n        mpz_set_ui(prod[k], 0);\n    }\n\n    for (int i = 0; i < deg; i++) mpz_set(res[i], prod[i]);\n\n    mpz_clear(tmp);\n    mpz_clear(lc_inv);\n    for (int i = 0; i < plen; i++) mpz_clear(prod[i]);\n    free(prod);\n}\n\n/* Evaluate polynomial at alpha = m mod N */\nstatic void poly_eval_at(mpz_t res, const mpz_t *p, int deg, const mpz_t m, const mpz_t N) {\n    mpz_t tmp, mpow;\n    mpz_inits(tmp, mpow, NULL);\n    mpz_set_ui(res, 0);\n    mpz_set_ui(mpow, 1);\n    for (int i = 0; i < deg; i++) {\n        mpz_mul(tmp, p[i], mpow);\n        mpz_add(res, res, tmp);\n        mpz_mod(res, res, N);\n        mpz_mul(mpow, mpow, m);\n        mpz_mod(mpow, mpow, N);\n    }\n    mpz_clears(tmp, mpow, NULL);\n}\n\n/* ── Standard polynomial operations ─────────────────────────── */\nstatic void poly_eval_mpz(mpz_t res, const mpz_t *c, int d, const mpz_t x) {\n    mpz_set(res, c[d]);\n    for (int i = d-1; i >= 0; i--) { mpz_mul(res, res, x); mpz_add(res, res, c[i]); }\n}\n\n/* f_hom(a,b) = sum c[i]*a^i*b^(d-i) */\nstatic void poly_hom(mpz_t res, const mpz_t *c, int d, const mpz_t a, const mpz_t b) {\n    mpz_t ai, bdi, t;\n    mpz_inits(ai, bdi, t, NULL);\n    mpz_set_ui(res, 0);\n    mpz_set_ui(ai, 1);\n    mpz_pow_ui(bdi, b, d);\n    for (int i = 0; i <= d; i++) {\n        mpz_mul(t, c[i], ai);\n        mpz_mul(t, t, bdi);\n        mpz_add(res, res, t);\n        if (i < d) {\n            mpz_mul(ai, ai, a);\n            if (mpz_sgn(b) != 0) mpz_divexact(bdi, bdi, b);\n        }\n    }\n    mpz_clears(ai, bdi, t, NULL);\n}\n\n/* ── ECM fallback ───────────────────────────────────────────── */\nstatic int try_ecm(mpz_t fac, mpz_t N, double deadline) {\n    ecm_params p;\n    ecm_init(p);\n    double b1s[] = {1e3,1e4,1e5,5e5,1e6,5e6,1e7,5e7,1e8};\n    for (int bi = 0; bi < 9 && wall() < deadline; bi++) {\n        for (int c = 0; c < 50 && wall() < deadline; c++) {\n            mpz_set_ui(fac, 0);\n            p->B1done = 1.0;\n            mpz_set_ui(p->sigma, 0);\n            int r = ecm_factor(fac, N, b1s[bi], p);\n            if (r > 0 && mpz_cmp_ui(fac, 1) > 0 && mpz_cmp(fac, N) < 0) {\n                ecm_clear(p); return 1;\n            }\n        }\n    }\n    ecm_clear(p);\n    return 0;\n}\n\n#define MAX_FB   4096\n#define MAX_RELS 16384\n\ntypedef struct {\n    long a, b;\n    int *ev;\n} rel_t;\n\nint main(int argc, char *argv[]) {\n    if (argc < 2) { fprintf(stderr, \"Usage: %s <N>\\n\", argv[0]); return 1; }\n\n    double t0 = wall(), deadline = t0 + 285.0;\n\n    mpz_t N, fac, tmp, tmp2;\n    mpz_inits(N, fac, tmp, tmp2, NULL);\n    mpz_set_str(N, argv[1], 10);\n\n    /* Trivials */\n    if (mpz_cmp_ui(N, 1) <= 0) return 1;\n    if (mpz_probab_prime_p(N, 25)) { gmp_printf(\"FACTOR: %Zd\\n\", N); return 0; }\n    if (mpz_even_p(N)) { printf(\"FACTOR: 2\\n\"); return 0; }\n    for (unsigned long p = 3; p < 100000; p += 2)\n        if (mpz_divisible_ui_p(N, p)) { printf(\"FACTOR: %lu\\n\", p); return 0; }\n    if (mpz_perfect_power_p(N))\n        for (int e = 2; e < 100; e++)\n            if (mpz_root(tmp, N, e) && mpz_cmp_ui(tmp, 1) > 0 && mpz_cmp(tmp, N) < 0)\n                for (unsigned long p2 = 2; p2 < 1000000; p2++)\n                    if (mpz_divisible_ui_p(tmp, p2)) {\n                        printf(\"FACTOR: %lu\\n\", p2); return 0;\n                    }\n\n    int ndig = (int)strlen(argv[1]);\n    double ln_N = mpz_sizeinbase(N, 2) * log(2.0);\n    double Le = sqrt(ln_N * log(ln_N));\n    fprintf(stderr, \"NFS: %d digits, L=%.1f\\n\", ndig, Le);\n\n    int deg = ndig < 35 ? 3 : ndig < 55 ? 4 : 5;\n\n    /* Base-m polynomial */\n    mpz_t m;\n    mpz_init(m);\n    mpz_root(m, N, deg + 1);\n\n    mpz_t co[10];\n    for (int i = 0; i <= deg; i++) mpz_init(co[i]);\n    {\n        mpz_t rem, pw;\n        mpz_inits(rem, pw, NULL);\n        mpz_set(rem, N);\n        for (int i = deg; i >= 1; i--) {\n            mpz_pow_ui(pw, m, i);\n            mpz_fdiv_qr(co[i], rem, rem, pw);\n        }\n        mpz_set(co[0], rem);\n        mpz_clears(rem, pw, NULL);\n    }\n    poly_eval_mpz(tmp, co, deg, m);\n    if (mpz_cmp(tmp, N) != 0) { fprintf(stderr, \"f(m)!=N\\n\"); goto ecm_fb; }\n\n    gmp_fprintf(stderr, \"m=%Zd deg=%d\\n\", m, deg);\n\n    /* Check if leading coeff is invertible mod N (it should be for valid N) */\n    {\n        mpz_t g;\n        mpz_init(g);\n        mpz_gcd(g, co[deg], N);\n        if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, N) < 0) {\n            gmp_printf(\"FACTOR: %Zd\\n\", g);\n            mpz_clear(g);\n            goto done;\n        }\n        mpz_clear(g);\n    }\n\n    /* Factor base bounds */\n    int fb_bnd = (int)exp(0.5 * Le);\n    if (fb_bnd < 2000) fb_bnd = 2000;\n    if (fb_bnd > 500000) fb_bnd = 500000;\n    int A_MAX = (int)fmin(exp(0.3 * Le), 100000.0);\n    if (A_MAX < 1000) A_MAX = 1000;\n    int B_MAX = A_MAX / 10;\n    if (B_MAX < 20) B_MAX = 20;\n    fprintf(stderr, \"FB=%d A=%d B=%d\\n\", fb_bnd, A_MAX, B_MAX);\n\n    int np;\n    int *primes = sieve_primes(fb_bnd, &np);\n\n    /* Rational FB */\n    int rfb_n = np < MAX_FB ? np : MAX_FB;\n    int *rfb = (int *)malloc(rfb_n * sizeof(int));\n    memcpy(rfb, primes, rfb_n * sizeof(int));\n\n    /* Algebraic FB: primes with roots of f mod p */\n    int afb_n = 0;\n    int *afb_p = (int *)malloc(MAX_FB * sizeof(int));\n    int *afb_r = (int *)malloc(MAX_FB * sizeof(int));\n    for (int i = 0; i < np && afb_n < MAX_FB; i++) {\n        int p = primes[i];\n        for (int r = 0; r < p && afb_n < MAX_FB; r++) {\n            long v = 0, rp = 1;\n            for (int j = 0; j <= deg; j++) {\n                long cm = ((long)mpz_fdiv_ui(co[j], p) + p) % p;\n                v = (v + cm * rp) % p;\n                rp = rp * r % p;\n            }\n            if (v == 0) { afb_p[afb_n] = p; afb_r[afb_n] = r; afb_n++; }\n        }\n    }\n    fprintf(stderr, \"RFB=%d AFB=%d\\n\", rfb_n, afb_n);\n\n    /* Exponent vector: [rat_sign | rat_exp[rfb_n] | alg_sign | alg_exp[afb_n]] */\n    int vlen = 1 + rfb_n + 1 + afb_n;\n    int target = vlen + 40;\n    if (target > MAX_RELS) target = MAX_RELS;\n    fprintf(stderr, \"vlen=%d target=%d\\n\", vlen, target);\n\n    int slen = 2 * A_MAX + 1;\n    float *rsv = (float *)malloc(slen * sizeof(float));\n    float *asv = (float *)malloc(slen * sizeof(float));\n    float *rlp = (float *)malloc(rfb_n * sizeof(float));\n    float *alp = (float *)malloc(afb_n * sizeof(float));\n    for (int i = 0; i < rfb_n; i++) rlp[i] = logf((float)rfb[i]);\n    for (int i = 0; i < afb_n; i++) alp[i] = logf((float)afb_p[i]);\n\n    double rne = log((double)A_MAX) + mpz_sizeinbase(m, 2) * log(2.0);\n    double ane = deg * log((double)A_MAX) + mpz_sizeinbase(co[deg], 2) * log(2.0);\n    float rthr = (float)(rne * 0.55);\n    float athr = (float)(ane * 0.55);\n\n    rel_t *rels = (rel_t *)malloc(MAX_RELS * sizeof(rel_t));\n    for (int i = 0; i < MAX_RELS; i++) rels[i].ev = (int *)calloc(vlen, sizeof(int));\n    int nrels = 0;\n\n    mpz_t rn, an, bz, az, td;\n    mpz_inits(rn, an, bz, az, td, NULL);\n\n    /* ── Line sieve ───────────────────────────────────────── */\n    fprintf(stderr, \"Sieving...\\n\");\n    for (long b = 1; b <= B_MAX && nrels < target; b++) {\n        if (wall() > deadline - 60) break;\n        memset(rsv, 0, slen * sizeof(float));\n        memset(asv, 0, slen * sizeof(float));\n\n        for (int i = 0; i < rfb_n; i++) {\n            int p = rfb[i];\n            long bm = ((b % p) * mpz_fdiv_ui(m, p)) % p;\n            long s = ((bm + A_MAX) % p + p) % p;\n            for (long j = s; j < slen; j += p) rsv[j] += rlp[i];\n        }\n        for (int i = 0; i < afb_n; i++) {\n            int p = afb_p[i];\n            long br = ((b % p) * afb_r[i]) % p;\n            long s = ((br + A_MAX) % p + p) % p;\n            for (long j = s; j < slen; j += p) asv[j] += alp[i];\n        }\n\n        for (int idx = 0; idx < slen && nrels < target; idx++) {\n            if (rsv[idx] < rthr || asv[idx] < athr) continue;\n            long a = (long)idx - A_MAX;\n            if (a == 0) continue;\n            long g = a < 0 ? -a : a, bb = b;\n            while (bb) { long t = g % bb; g = bb; bb = t; }\n            if (g != 1) continue;\n\n            mpz_set_si(az, a);\n            mpz_set_si(bz, b);\n            mpz_mul(rn, bz, m);\n            mpz_sub(rn, az, rn);\n\n            int ev[MAX_FB * 2 + 4];\n            memset(ev, 0, vlen * sizeof(int));\n            mpz_abs(td, rn);\n            ev[0] = mpz_sgn(rn) < 0 ? 1 : 0;\n\n            for (int j = 0; j < rfb_n; j++) {\n                unsigned long p = rfb[j];\n                while (mpz_divisible_ui_p(td, p)) { mpz_divexact_ui(td, td, p); ev[1+j]++; }\n            }\n            if (mpz_cmp_ui(td, 1) != 0) continue;\n\n            poly_hom(an, co, deg, az, bz);\n            mpz_abs(td, an);\n            ev[1 + rfb_n] = mpz_sgn(an) < 0 ? 1 : 0;\n\n            for (int j = 0; j < afb_n; j++) {\n                unsigned long p = afb_p[j];\n                while (mpz_divisible_ui_p(td, p)) { mpz_divexact_ui(td, td, p); ev[1+rfb_n+1+j]++; }\n            }\n            if (mpz_cmp_ui(td, 1) != 0) continue;\n\n            rels[nrels].a = a;\n            rels[nrels].b = b;\n            memcpy(rels[nrels].ev, ev, vlen * sizeof(int));\n            nrels++;\n\n            if (nrels % 100 == 0)\n                fprintf(stderr, \"  b=%ld: %d rels (%.1fs)\\n\", b, nrels, wall() - t0);\n        }\n    }\n\n    fprintf(stderr, \"Got %d relations in %.1fs\\n\", nrels, wall() - t0);\n    if (nrels < vlen + 1) { fprintf(stderr, \"Not enough rels\\n\"); goto ecm_fb; }\n\n    /* ── Gaussian elimination ─────────────────────────────── */\n    {\n        int acols = vlen + nrels;\n        mat_t M;\n        mat_init(&M, nrels, acols);\n        for (int i = 0; i < nrels; i++) {\n            for (int j = 0; j < vlen; j++)\n                if (rels[i].ev[j] & 1) mat_set(&M, i, j);\n            mat_set(&M, i, vlen + i);\n        }\n\n        fprintf(stderr, \"GaussElim %dx%d...\\n\", nrels, vlen);\n        int *piv = (int *)malloc(vlen * sizeof(int));\n        memset(piv, -1, vlen * sizeof(int));\n        for (int c = 0; c < vlen; c++) {\n            int pr = -1;\n            for (int r = 0; r < nrels; r++) {\n                if (!mat_get(&M, r, c)) continue;\n                int used = 0;\n                for (int c2 = 0; c2 < c; c2++)\n                    if (piv[c2] == r) { used = 1; break; }\n                if (!used) { pr = r; break; }\n            }\n            if (pr < 0) continue;\n            piv[c] = pr;\n            for (int r = 0; r < nrels; r++)\n                if (r != pr && mat_get(&M, r, c)) mat_xor(&M, r, pr);\n        }\n\n        /* ── Factor extraction ────────────────────────────── */\n        fprintf(stderr, \"Finding factors...\\n\");\n        int found = 0;\n\n        for (int row = 0; row < nrels && !found; row++) {\n            if (wall() > deadline - 10) break;\n\n            int null = 1;\n            for (int c = 0; c < vlen; c++)\n                if (mat_get(&M, row, c)) { null = 0; break; }\n            if (!null) continue;\n\n            int *dep = (int *)malloc(nrels * sizeof(int));\n            int nd = 0;\n            for (int i = 0; i < nrels; i++)\n                if (mat_get(&M, row, vlen + i)) dep[nd++] = i;\n            if (nd == 0) { free(dep); continue; }\n\n            fprintf(stderr, \"  dep: %d rels\\n\", nd);\n\n            /* Sum exponents, verify even */\n            int *tot = (int *)calloc(vlen, sizeof(int));\n            for (int k = 0; k < nd; k++)\n                for (int j = 0; j < vlen; j++)\n                    tot[j] += rels[dep[k]].ev[j];\n            int ok = 1;\n            for (int j = 0; j < vlen; j++) if (tot[j] & 1) { ok = 0; break; }\n            if (!ok) { free(dep); free(tot); continue; }\n\n            /*\n             * Square root extraction using BOTH sides:\n             *\n             * X (rational sqrt): computed from rational exponent half-powers.\n             *   X = (-1)^(sign/2) * prod(p^(e_p/2)) mod N\n             *   X^2 ≡ prod(a_i - b_i*m) (mod N)\n             *\n             * Y (algebraic sqrt): compute product of (a_i - b_i*alpha)\n             *   in the polynomial ring Z[alpha]/(f(alpha)) mod N, then\n             *   take the polynomial square root, and evaluate at alpha = m.\n             *   Y^2 ≡ prod(a_i - b_i*m) (mod N) [via the homomorphism alpha -> m]\n             *\n             * Then gcd(X - Y, N) gives a factor (with probability ~1/2).\n             */\n\n            /* X: rational square root */\n            mpz_t X, Y, g;\n            mpz_inits(X, Y, g, NULL);\n            mpz_set_ui(X, 1);\n            for (int j = 0; j < rfb_n; j++) {\n                int half = tot[1+j] / 2;\n                if (half > 0) {\n                    mpz_set_ui(tmp, rfb[j]);\n                    mpz_powm_ui(tmp, tmp, half, N);\n                    mpz_mul(X, X, tmp);\n                    mpz_mod(X, X, N);\n                }\n            }\n            if ((tot[0] / 2) & 1) mpz_sub(X, N, X);\n\n            /* Y: algebraic square root via polynomial arithmetic.\n             *\n             * Compute gamma = prod(a_i - b_i * alpha) in Z[alpha]/(f) mod N\n             * where alpha is a root of f(x).\n             * Each factor (a - b*alpha) is a degree-1 polynomial: a - b*alpha.\n             * We multiply them all together modulo f(x) and modulo N.\n             *\n             * Then gamma should be a perfect square in the ring.\n             * gamma = delta^2 where delta is another polynomial.\n             *\n             * To find delta, we can try:\n             * 1. If gamma = prod(p_i^{e_i}) where p_i are algebraic prime ideals,\n             *    and all e_i are even, then delta = prod(p_i^{e_i/2}).\n             * 2. More practically: gamma evaluated at alpha=m gives\n             *    prod(a_i - b_i*m) mod N = X^2. So we know gamma(m) = X^2 mod N.\n             *    We want delta such that delta(m) = Y and Y^2 = X^2 mod N\n             *    but Y != ±X mod N (hopefully).\n             *\n             * The simplest approach: compute gamma as a polynomial, then\n             * try to extract its polynomial square root by Hensel lifting\n             * or by computing gamma^((N+1)/2) if N is prime-like (it's not).\n             *\n             * Alternative practical approach: use Tonelli-Shanks in the\n             * polynomial ring, or simply compute the square root using\n             * the known factorization.\n             *\n             * SIMPLER approach for small number field degree:\n             * We know gamma = prod(a_i - b_i*alpha) mod f(alpha) mod N.\n             * We want delta s.t. delta^2 = gamma mod f mod N.\n             * We can compute delta = gamma^((N^deg + 1)/2) mod f mod N\n             * using repeated squaring in the polynomial ring.\n             * This works because the multiplicative group of\n             * GF(N)[alpha]/(f) has order ~N^deg - 1 when N is prime,\n             * and for composite N it might give us a factor.\n             */\n\n            /* Compute gamma = prod(a_i - b_i*alpha) mod f mod N */\n            mpz_t *gamma = (mpz_t *)malloc(deg * sizeof(mpz_t));\n            for (int i = 0; i < deg; i++) mpz_init(gamma[i]);\n\n            /* Start with gamma = 1 (constant polynomial) */\n            mpz_set_ui(gamma[0], 1);\n            for (int i = 1; i < deg; i++) mpz_set_ui(gamma[i], 0);\n\n            mpz_t *factor_poly = (mpz_t *)malloc(deg * sizeof(mpz_t));\n            for (int i = 0; i < deg; i++) mpz_init(factor_poly[i]);\n\n            for (int k = 0; k < nd; k++) {\n                /* factor = a - b*alpha, i.e., coeff[0] = a, coeff[1] = -b */\n                mpz_set_si(factor_poly[0], rels[dep[k]].a);\n                mpz_mod(factor_poly[0], factor_poly[0], N);\n                mpz_set_si(factor_poly[1], -rels[dep[k]].b);\n                mpz_mod(factor_poly[1], factor_poly[1], N);\n                for (int i = 2; i < deg; i++) mpz_set_ui(factor_poly[i], 0);\n\n                poly_mul_mod(gamma, gamma, factor_poly, co, deg, N);\n            }\n\n            /* Now gamma(m) should equal prod(a_i - b_i*m) mod N = X^2 mod N */\n            /* Verify this */\n            poly_eval_at(tmp, gamma, deg, m, N);\n            mpz_mul(tmp2, X, X);\n            mpz_mod(tmp2, tmp2, N);\n\n            /* The algebraic sqrt approach:\n             * Compute delta = gamma^((N+1)/2) mod f mod N using\n             * polynomial exponentiation. If N = p*q, this will fail\n             * (non-deterministically) and give us a factor via gcd. */\n\n            /* But (N+1)/2 might not give a sqrt for composite N.\n             * Instead, for each dep, try:\n             * delta = gamma^e where e = (N^deg + 1) / 2\n             * This is very expensive for large N.\n             *\n             * PRACTICAL ALTERNATIVE:\n             * Since we know the prime factorization of the algebraic norm\n             * (from the factor base), and we know which prime ideals divide\n             * gamma, we can construct the square root directly.\n             *\n             * For each algebraic prime ideal (p, alpha - r):\n             *   - Its contribution to gamma has exponent e (even)\n             *   - The square root gets exponent e/2\n             *   - (p, alpha - r)^e contributes p^e to the norm\n             *   - The image of the square root under phi: alpha -> m\n             *     gives a specific value mod N.\n             *\n             * The norm of the algebraic square root = prod(afb_p[j]^(half_exp))\n             * But the actual value of phi(delta) depends on HOW the prime\n             * ideals factor, not just their norms.\n             *\n             * KEY INSIGHT: phi(p, alpha-r) maps alpha -> m, so the ideal\n             * (p, alpha-r) acts on the image as: the element is a unit times\n             * the appropriate power. For a principal ideal (a - b*alpha),\n             * phi gives (a - b*m). For the square root, we need to work out\n             * what phi of the half-power is.\n             *\n             * Actually, the SIMPLEST correct approach:\n             * Since gamma is a perfect square in Z[alpha]/(f) modulo each\n             * prime factor of N, we can compute the square root modulo\n             * each prime factor and use CRT. But we don't know the prime\n             * factors (that's what we're trying to find!).\n             *\n             * The standard NFS uses Couveignes' algorithm or Montgomery's\n             * method. These are complex but feasible.\n             *\n             * For our implementation, use the POWER approach:\n             * delta = gamma^((p+1)/2) mod f mod p, for p | N.\n             * Since we don't know p, we compute gamma^((N+1)/2) mod f mod N.\n             * If N = p*q, then by CRT this computes gamma^((N+1)/2 mod (p-1))\n             * separately mod p and mod q. This might or might not be the\n             * square root. But when it fails, the intermediate computations\n             * might reveal a factor through failed inversions.\n             *\n             * Actually a better approach: compute gamma^((N-1)/2) mod f mod N.\n             * This should be ±1 (the Jacobi symbol). Then\n             * delta = gamma^((N+1)/4) if N ≡ 3 (mod 4), etc.\n             * For general N (composite), this is not guaranteed to work\n             * but will often produce useful information.\n             */\n\n            /* Try the simplest approach: compute gamma^exp mod f mod N\n               where exp = (N+1)/2. Use binary exponentiation in the\n               polynomial ring. */\n            {\n                mpz_t exp;\n                mpz_init(exp);\n                mpz_add_ui(exp, N, 1);\n                mpz_fdiv_q_2exp(exp, exp, 1); /* exp = (N+1)/2 */\n\n                mpz_t *base = (mpz_t *)malloc(deg * sizeof(mpz_t));\n                mpz_t *result = (mpz_t *)malloc(deg * sizeof(mpz_t));\n                mpz_t *temp = (mpz_t *)malloc(deg * sizeof(mpz_t));\n                for (int i = 0; i < deg; i++) {\n                    mpz_init_set(base[i], gamma[i]);\n                    mpz_init(result[i]);\n                    mpz_init(temp[i]);\n                }\n                /* result = 1 */\n                mpz_set_ui(result[0], 1);\n                for (int i = 1; i < deg; i++) mpz_set_ui(result[i], 0);\n\n                /* Binary exponentiation */\n                int bits = mpz_sizeinbase(exp, 2);\n                for (int bit = bits - 1; bit >= 0; bit--) {\n                    /* result = result^2 */\n                    poly_mul_mod(temp, result, result, co, deg, N);\n                    for (int i = 0; i < deg; i++) mpz_set(result[i], temp[i]);\n\n                    if (mpz_tstbit(exp, bit)) {\n                        /* result = result * base */\n                        poly_mul_mod(temp, result, base, co, deg, N);\n                        for (int i = 0; i < deg; i++) mpz_set(result[i], temp[i]);\n                    }\n                }\n\n                /* Y = result evaluated at alpha = m */\n                poly_eval_at(Y, result, deg, m, N);\n\n                for (int i = 0; i < deg; i++) {\n                    mpz_clear(base[i]);\n                    mpz_clear(result[i]);\n                    mpz_clear(temp[i]);\n                }\n                free(base); free(result); free(temp);\n                mpz_clear(exp);\n            }\n\n            /* Try gcd(X ± Y, N) */\n            for (int s = 0; s < 2 && !found; s++) {\n                if (s == 0) mpz_sub(tmp, X, Y);\n                else        mpz_add(tmp, X, Y);\n                mpz_mod(tmp, tmp, N);\n                mpz_gcd(g, tmp, N);\n                if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, N) < 0) {\n                    gmp_printf(\"FACTOR: %Zd\\n\", g);\n                    found = 1;\n                }\n            }\n\n            /* Also try with negated X */\n            if (!found) {\n                mpz_sub(tmp, N, X);  /* -X mod N */\n                for (int s = 0; s < 2 && !found; s++) {\n                    if (s == 0) mpz_sub(tmp2, tmp, Y);\n                    else        mpz_add(tmp2, tmp, Y);\n                    mpz_mod(tmp2, tmp2, N);\n                    mpz_gcd(g, tmp2, N);\n                    if (mpz_cmp_ui(g, 1) > 0 && mpz_cmp(g, N) < 0) {\n                        gmp_printf(\"FACTOR: %Zd\\n\", g);\n                        found = 1;\n                    }\n                }\n            }\n\n            for (int i = 0; i < deg; i++) {\n                mpz_clear(gamma[i]);\n                mpz_clear(factor_poly[i]);\n            }\n            free(gamma); free(factor_poly);\n            mpz_clears(X, Y, g, NULL);\n            free(dep); free(tot);\n        }\n\n        free(piv);\n        mat_free(&M);\n        if (found) goto done;\n        fprintf(stderr, \"NFS extraction failed\\n\");\n    }\n\necm_fb:\n    fprintf(stderr, \"ECM fallback...\\n\");\n    if (try_ecm(fac, N, deadline))\n        gmp_printf(\"FACTOR: %Zd\\n\", fac);\n    else\n        fprintf(stderr, \"No factor fo