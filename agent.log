{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xo1trNbFhR8ohsBTp9NKoS","type":"tool_result","content":"   178→/* ===== MPQS sieve ===== */\n   179→static void mpqs_sieve(const mpz_t kN, const mpz_t N, const fb_t *fb, int M,\n   180→                       unsigned long lp_bound, int poly_idx,\n   181→                       relset_t *full, relset_t *partial) {\n   182→    mpz_t target, q, A, B, C, tmp, val, res, q_inv;\n   183→    mpz_inits(target, q, A, B, C, tmp, val, res, q_inv, NULL);\n   184→\n   185→    int n_bits = mpz_sizeinbase(kN, 2);\n   186→    mpz_mul_ui(tmp, kN, 2); mpz_sqrt(target, tmp); mpz_sqrt(target, target);\n   187→    unsigned long sqM = (unsigned long)sqrt((double)M);\n   188→    if (sqM < 2) sqM = 2;\n   189→    mpz_tdiv_q_ui(target, target, sqM);\n   190→    mpz_add_ui(target, target, poly_idx * 100 + 42);\n   191→    mpz_nextprime(q, target);\n   192→\n   193→    int ok = 0;\n   194→    for (int att = 0; att < 200 && !ok; att++) {\n   195→        if (!mpz_fits_ulong_p(q)) { mpz_nextprime(q, q); continue; }\n   196→        unsigned long qv = mpz_get_ui(q);\n   197→        long nq = mpz_fdiv_ui(kN, qv);\n   198→        long sq = mod_sqrt_long(nq, qv);\n   199→        if (sq <= 0) { mpz_nextprime(q, q); continue; }\n   200→        mpz_mul(A, q, q); mpz_set_ui(B, sq);\n   201→        mpz_set_ui(tmp, (unsigned long)sq * sq); mpz_sub(tmp, kN, tmp);\n   202→        if (!mpz_divisible_ui_p(tmp, qv)) { mpz_nextprime(q, q); continue; }\n   203→        mpz_tdiv_q_ui(tmp, tmp, qv);\n   204→        mpz_t inv, pz; mpz_inits(inv, pz, NULL);\n   205→        mpz_set_ui(inv, 2 * sq % qv); mpz_set_ui(pz, qv);\n   206→        if (!mpz_invert(inv, inv, pz)) { mpz_clears(inv, pz, NULL); mpz_nextprime(q, q); continue; }\n   207→        mpz_mul(tmp, tmp, inv); mpz_mod_ui(tmp, tmp, qv);\n   208→        mpz_mul_ui(tmp, tmp, qv); mpz_add(B, B, tmp);\n   209→        mpz_clears(inv, pz, NULL);\n   210→        mpz_mul(tmp, B, B); mpz_sub(tmp, tmp, kN);\n   211→        if (!mpz_divisible_p(tmp, A)) { mpz_nextprime(q, q); continue; }\n   212→        mpz_mul(C, B, B); mpz_sub(C, C, kN); mpz_tdiv_q(C, C, A);\n   213→        mpz_set_ui(tmp, mpz_get_ui(q)); mpz_invert(q_inv, tmp, kN);\n   214→        ok = 1;\n   215→    }\n   216→    if (!ok) { mpz_clears(target, q, A, B, C, tmp, val, res, q_inv, NULL); return; }\n   217→\n   218→    int slen = 2 * M + 1;\n   219→    double log2_max = log2(M) + n_bits / 2.0 + 0.5;\n   220→    int threshold = (int)((log2_max - log2(lp_bound > 1 ? lp_bound : 2)) * 1024);\n   221→    if (threshold < 0) threshold = 0;\n   222→    int *sieve = (int *)calloc(slen, sizeof(int));\n   223→\n   224→    for (int i = 0; i < fb->count; i++) {\n   225→        int p = fb->primes[i]; long sq = fb->sqrtN[i]; int logp = (int)(log2(p)*1024);\n   226→        if (p == 2) { for (long j = 0; j < slen; j++) sieve[j] += logp; continue; }\n   227→        long Ap = mpz_fdiv_ui(A, p), Bp = mpz_fdiv_ui(B, p);\n   228→        if (Ap == 0) {\n   229→            if (Bp != 0) {\n   230→                mpz_t i2, p2; mpz_inits(i2, p2, NULL);\n   231→                mpz_set_ui(i2, 2*Bp%p); mpz_set_ui(p2, p);\n   232→                if (mpz_invert(i2, i2, p2)) {\n   233→                    long Cp = mpz_fdiv_ui(C, p);\n   234→                    long root = (p - Cp) % p * mpz_get_ui(i2) % p;\n   235→                    long start = ((root + M) % p + p) % p;\n   236→                    for (long j = start; j < slen; j += p) sieve[j] += logp;\n   237→                }\n   238→                mpz_clears(i2, p2, NULL);\n   239→            }\n   240→            continue;\n   241→        }\n   242→        mpz_t ai, pz; mpz_inits(ai, pz, NULL);\n   243→        mpz_set_ui(ai, Ap); mpz_set_ui(pz, p);\n   244→        if (!mpz_invert(ai, ai, pz)) { mpz_clears(ai, pz, NULL); continue; }\n   245→        long aiv = mpz_get_ui(ai); mpz_clears(ai, pz, NULL);\n   246→        long r1 = ((sq - Bp) % p + p) % p * aiv % p;\n   247→        long r2 = ((p - sq - Bp) % p + p) % p * aiv % p;\n   248→        long s1 = ((r1 + M) % p + p) % p;\n   249→        long s2 = ((r2 + M) % p + p) % p;\n   250→        for (long j = s1; j < slen; j += p) sieve[j] += logp;\n   251→        if (s1 != s2) for (long j = s2; j < slen; j += p) sieve[j] += logp;\n   252→    }\n   253→\n   254→    int *exps = (int *)calloc(fb->count + 1, sizeof(int));\n   255→    for (int j = 0; j < slen; j++) {\n   256→        if (sieve[j] < threshold) continue;\n   257→        long x = (long)j - M;"}]},"parent_tool_use_id":"toolu_01PJZMZ7sckgdGWoF8ezTo31","session_id":"f16ee78b-ee57-47d2-a561-91e9aefa955b","uuid":"676a9eea-4b05-4b8e-8d34-aaae36225a03","timestamp":"2026-03-24T03:07:45.089Z"}
